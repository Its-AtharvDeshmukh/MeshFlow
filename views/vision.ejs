<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <%- include('partials/head') %>
    <title>Vision 2030 | MeshFlow X</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        :root {
            --bg-apple: #000000;
            --glass-bg: rgba(10, 10, 12, 0.6);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-primary: #f5f5f7;
            --neon-blue: #3b82f6;
            --neon-purple: #8b5cf6;
            --neon-cyan: #06b6d4;
        }

        body {
            background-color: var(--bg-apple);
            color: var(--text-primary);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Apple-style tight tracking */
        .tracking-apple { letter-spacing: -0.04em; }
        .tracking-apple-tight { letter-spacing: -0.06em; }

        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

        /* Ultra-premium frosted glass (visionOS style) */
        .bento-card {
            background: var(--glass-bg);
            backdrop-filter: blur(48px);
            -webkit-backdrop-filter: blur(48px);
            border: 1px solid var(--glass-border);
            border-top: 1px solid rgba(255,255,255,0.15);
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.02);
            border-radius: 32px;
            overflow: hidden;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .bento-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 40px 80px -12px rgba(0, 0, 0, 0.8), inset 0 0 0 1px rgba(255, 255, 255, 0.1);
        }

        /* Ambient Aurora Backgrounds */
        .aurora-container {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            overflow: hidden; z-index: 0; pointer-events: none; background: #000;
        }
        .aurora-blob {
            position: absolute; border-radius: 50%; filter: blur(140px); opacity: 0.3;
            animation: aurora-float 20s cubic-bezier(0.4, 0, 0.2, 1) infinite alternate;
        }
        .blob-1 { background: var(--neon-blue); width: 50vw; height: 50vw; top: -10vw; left: -10vw; }
        .blob-2 { background: var(--neon-purple); width: 40vw; height: 40vw; top: 40vw; right: -10vw; animation-delay: -5s; }

        @keyframes aurora-float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(5%, 10%) scale(1.1); }
            100% { transform: translate(-5%, 5%) scale(0.95); }
        }

        .text-gradient-apple {
            background: linear-gradient(135deg, #fff 0%, #a5b4fc 50%, #fbcfe8 100%);
            -webkit-background-clip: text;
            color: transparent;
        }

        /* Cinematic Reveals */
        .reveal {
            opacity: 0;
            transform: translateY(40px) scale(0.98);
            transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        /* Roadmap Badges */
        .vision-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 4px 12px; border-radius: 100px;
            background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.2);
            color: #c4b5fd; font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.1em;
            box-shadow: 0 0 20px rgba(139, 92, 246, 0.15);
        }

        /* Animated Pipeline Lines */
        .pipeline-line {
            width: 2px; height: 40px; background: rgba(255,255,255,0.1); margin: 0 auto; position: relative; overflow: hidden;
        }
        .pipeline-line::after {
            content: ''; position: absolute; top: -50%; left: 0; right: 0; height: 50%;
            background: linear-gradient(to bottom, transparent, var(--neon-purple), transparent);
            animation: flow-down 2s linear infinite;
        }
        @keyframes flow-down { 0% { top: -50%; } 100% { top: 100%; } }

        .mesh-node {
            width: 8px; height: 8px; border-radius: 50%; background: var(--neon-cyan);
            box-shadow: 0 0 15px var(--neon-cyan); position: relative;
        }
        .mesh-node::after {
            content: ''; position: absolute; inset: -4px; border-radius: 50%;
            border: 1px solid var(--neon-cyan); animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
        }
    </style>
</head>
<body class="flex overflow-hidden relative h-screen w-screen">

    <!-- Cinematic Aurora Engine with Noise Texture -->
    <div class="aurora-container">
        <div class="aurora-blob blob-1"></div>
        <div class="aurora-blob blob-2"></div>
        <div class="absolute inset-0 opacity-[0.12] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    </div>

    <!-- Premium Top Navigation -->
    <header class="fixed top-0 left-0 w-full z-[9999] bg-black/40 backdrop-blur-2xl border-b border-white/5">
        <div class="max-w-7xl mx-auto px-6 lg:px-10 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3 cursor-pointer" onclick="window.location.href='/'">
                <div class="w-10 h-10 bg-black/50 border border-white/10 rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(139,92,246,0.15)] transition-colors relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-500/20 to-blue-500/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <img src="/assets/mesh-logo.png" alt="MeshFlow X" class="w-6 h-6 object-contain relative z-10 filter drop-shadow-md">
                </div>
                <span class="text-white font-display font-bold tracking-tight text-xl drop-shadow-md">MeshFlow <span class="text-purple-500">X</span></span>
            </div>
            <nav class="hidden md:flex items-center gap-10">
                <a href="/" class="text-zinc-400 hover:text-white transition-colors text-sm font-medium tracking-wide">Core Workspace</a>
                <a href="/how-it-works" class="text-zinc-400 hover:text-white transition-colors text-sm font-medium tracking-wide">How It Works</a>
                <a href="/vision" class="text-white font-bold text-sm tracking-wide flex items-center gap-2 drop-shadow-md">
                    <div class="w-1.5 h-1.5 rounded-full bg-purple-500 shadow-[0_0_8px_#8b5cf6]"></div> Vision 2030
                </a>
            </nav>
        </div>
    </header>

    <main class="flex-1 relative flex flex-col overflow-y-auto custom-scrollbar h-full w-full z-10" id="scroll-container">
        
        <!-- HERO -->
        <section class="min-h-[95vh] flex flex-col items-center justify-center text-center px-6 pt-32 relative">
            <div class="vision-badge mb-8 reveal shadow-2xl backdrop-blur-xl">
                <i data-lucide="telescope" class="w-3.5 h-3.5"></i> MeshFlow X Vision 2030
            </div>
            
            <h1 class="text-6xl md:text-[110px] font-bold tracking-apple-tight leading-[0.95] text-white mb-8 reveal delay-100 max-w-6xl drop-shadow-2xl">
                Building the World’s <br>
                <span class="text-gradient-apple">Intelligent AI Operating System.</span>
            </h1>
            
            <p class="text-white/50 text-xl md:text-3xl max-w-3xl mx-auto font-medium tracking-tight leading-relaxed mb-16 reveal delay-200">
                A definitive roadmap beyond the hackathon. From orchestrating documents to orchestrating the global enterprise ecosystem.
            </p>

            <button onclick="document.getElementById('evolution-section').scrollIntoView({behavior: 'smooth'})" class="px-8 py-4 bg-white text-black hover:scale-105 text-sm font-bold rounded-full transition-all shadow-[0_0_40px_rgba(255,255,255,0.2)] flex items-center gap-2 reveal delay-300">
                Explore Our Future <i data-lucide="arrow-down" class="w-4 h-4"></i>
            </button>
        </section>

        <!-- SECTION 1 & 2: TODAY VS TOMORROW -->
        <section id="evolution-section" class="py-24 px-6 max-w-[1400px] mx-auto w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Today (MVP) -->
                <div class="bento-card p-10 md:p-14 reveal flex flex-col items-center text-center">
                    <span class="px-3 py-1 text-[10px] font-mono font-bold uppercase tracking-widest text-zinc-400 bg-white/5 border border-white/10 rounded-full mb-8">Current Capabilities</span>
                    <h3 class="text-3xl font-bold tracking-apple text-white mb-10">Today</h3>
                    
                    <div class="flex flex-col items-center w-full max-w-xs">
                        <div class="w-full p-4 bg-white/5 border border-white/10 rounded-xl font-mono text-xs">Document Upload</div>
                        <div class="pipeline-line my-2"></div>
                        <div class="w-full p-4 bg-white/5 border border-white/10 rounded-xl font-mono text-xs">Workflow DAG</div>
                        <div class="pipeline-line my-2"></div>
                        <div class="w-full p-4 bg-white/5 border border-white/10 rounded-xl font-mono text-xs text-blue-400">Multiple AI Models</div>
                        <div class="pipeline-line my-2"></div>
                        <div class="w-full p-4 bg-white/5 border border-white/10 rounded-xl font-mono text-xs">Executive Report</div>
                    </div>
                </div>

                <!-- Tomorrow (Vision) -->
                <div class="bento-card p-10 md:p-14 reveal delay-100 flex flex-col items-center text-center border-purple-500/20 bg-purple-900/5 relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(139,92,246,0.1)_0,transparent_60%)] pointer-events-none"></div>
                    <span class="vision-badge mb-8 relative z-10">Future Vision</span>
                    <h3 class="text-3xl font-bold tracking-apple text-white mb-10 relative z-10">Tomorrow</h3>
                    
                    <div class="flex flex-col items-center w-full max-w-sm relative z-10">
                        <div class="w-full p-4 bg-black/50 border border-white/10 rounded-xl font-mono text-xs shadow-inner flex justify-center gap-3 flex-wrap text-zinc-400">
                            <span>Docs</span><span>Images</span><span>Video</span><span>Audio</span><span>Code</span><span>Web</span>
                        </div>
                        <div class="pipeline-line my-2"></div>
                        <div class="w-full p-4 bg-black/50 border border-purple-500/30 rounded-xl font-mono text-xs text-purple-300 shadow-[0_0_20px_rgba(139,92,246,0.2)]">Universal Mesh Orchestration</div>
                        <div class="pipeline-line my-2"></div>
                        <div class="w-full p-4 bg-black/50 border border-blue-500/30 rounded-xl font-mono text-xs text-blue-300 shadow-[0_0_20px_rgba(59,130,246,0.2)] flex justify-center gap-3">
                            <i data-lucide="bot" class="w-4 h-4"></i> Autonomous Agents
                        </div>
                        <div class="pipeline-line my-2"></div>
                        <div class="w-full p-4 bg-gradient-to-r from-purple-600 to-blue-600 border border-white/20 rounded-xl font-bold text-sm text-white shadow-[0_0_30px_rgba(139,92,246,0.4)]">Entire AI Operating System</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 3: UNIVERSAL AI ENGINE -->
        <section class="py-24 px-6 max-w-6xl mx-auto w-full text-center">
            <div class="reveal mb-16">
                <span class="vision-badge mb-4">Planned Roadmap</span>
                <h2 class="text-4xl md:text-5xl font-bold tracking-apple text-white mb-4">The Universal AI Engine.</h2>
                <p class="text-xl text-white/50 max-w-3xl mx-auto font-medium">Every input type in the digital world automatically converted into a structured execution workflow.</p>
            </div>

            <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto reveal delay-100">
                <% const inputs = ['PDF', 'DOCX', 'Excel', 'CSV', 'PowerPoint', 'Emails', 'Images', 'Screenshots', 'Audio', 'Meetings', 'Videos', 'GitHub Repos', 'Websites', 'Research Papers', 'Medical Reports', 'Financials', 'Contracts', 'Invoices', 'Source Code', 'Databases', 'Cloud Systems', 'Live APIs']; %>
                <% inputs.forEach(input => { %>
                    <div class="px-5 py-3 rounded-2xl bg-white/5 border border-white/10 hover:border-blue-500/50 hover:bg-blue-500/10 transition-colors text-sm font-medium text-zinc-300 shadow-inner">
                        <%= input %>
                    </div>
                <% }) %>
            </div>
        </section>

        <!-- SECTION 4: FUTURE AI CAPABILITIES GRID -->
        <section class="py-32 px-6 max-w-[1400px] mx-auto w-full">
            <div class="text-center mb-16 reveal">
                <h2 class="text-4xl md:text-5xl font-bold tracking-apple text-white mb-4">Multimodal Omnipotence.</h2>
                <p class="text-xl text-white/50 max-w-2xl mx-auto font-medium">The expansion of MeshFlow X capabilities across every vertical.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% 
                const capabilities = [
                    { title: "Coding Intelligence", icon: "code", color: "text-indigo-400", items: ["Analyze repositories", "Generate code", "Refactor code", "Review pull requests", "Detect bugs", "Generate documentation", "Developer Copilot"] },
                    { title: "Video Intelligence", icon: "video", color: "text-rose-400", items: ["Generate videos", "Edit videos", "Create advertisements", "Educational videos", "Automatic subtitles", "Video translation", "Scene planning"] },
                    { title: "Image Intelligence", icon: "image", color: "text-amber-400", items: ["Generate images", "UI mockups", "Architecture diagrams", "Mind maps", "Infographics", "Product designs", "Medical visualization"] },
                    { title: "Voice Intelligence", icon: "mic", color: "text-cyan-400", items: ["Voice cloning", "Meeting assistant", "Podcast generation", "Real-time transcription", "AI receptionist", "Interactive conversations"] },
                    { title: "Research Intelligence", icon: "flask-conical", color: "text-blue-400", items: ["Scientific research", "Patent analysis", "Medical research", "Competitive analysis", "Literature review", "Knowledge graph generation"] },
                    { title: "Business Intelligence", icon: "briefcase", color: "text-emerald-400", items: ["Strategy generation", "Business planning", "Risk analysis", "Financial forecasting", "KPI dashboards", "Market predictions", "Executive reports"] },
                    { title: "Education Intelligence", icon: "graduation-cap", color: "text-orange-400", items: ["AI Tutor", "Course generation", "Quiz generation", "Learning plans", "Exam preparation", "Student analytics", "Teacher assistant"] },
                    { title: "Healthcare Intelligence", icon: "activity", color: "text-red-400", items: ["Medical reports", "Patient workflow", "Clinical decision support", "Treatment planning", "Radiology workflows", "Medical AI agents"] },
                    { title: "Enterprise Intelligence", icon: "building", color: "text-purple-400", items: ["Company knowledge", "Workflow automation", "HR assistant", "Finance assistant", "Legal assistant", "Enterprise search"] }
                ];
                %>
                
                <% capabilities.forEach((cap, i) => { %>
                    <div class="bento-card p-8 reveal hover:scale-[1.02]" style="transition-delay: <%= i * 50 %>ms">
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
                                <i data-lucide="<%= cap.icon %>" class="w-6 h-6 <%= cap.color %>"></i>
                            </div>
                            <span class="vision-badge border-white/10 bg-white/5 text-zinc-400">Future</span>
                        </div>
                        <h3 class="text-xl font-bold tracking-apple text-white mb-4"><%= cap.title %></h3>
                        <ul class="space-y-2 text-sm text-zinc-400">
                            <% cap.items.forEach(item => { %>
                                <li class="flex gap-2 items-center"><i data-lucide="chevron-right" class="w-3 h-3 <%= cap.color %> opacity-50"></i> <%= item %></li>
                            <% }) %>
                        </ul>
                    </div>
                <% }) %>
            </div>
        </section>

        <!-- SECTION 5: FUTURE WORKFLOW -->
        <section class="py-32 px-6 max-w-4xl mx-auto w-full text-center">
            <div class="bento-card p-10 md:p-16 reveal relative overflow-hidden border-purple-500/20 bg-[#0a0a0c]">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(139,92,246,0.1)_0,transparent_60%)] pointer-events-none"></div>
                
                <span class="vision-badge mb-6 relative z-10">Advanced Workflow Vision</span>
                <h2 class="text-3xl md:text-4xl font-bold tracking-apple text-white mb-12 relative z-10">The Automated Content Pipeline</h2>

                <div class="flex flex-col items-center w-full relative z-10">
                    <div class="w-full max-w-xs p-4 bg-white/5 border border-white/10 rounded-2xl font-bold text-sm shadow-inner flex items-center justify-center gap-3">
                        <i data-lucide="upload" class="w-4 h-4 text-purple-400"></i> User Uploads Video
                    </div>
                    
                    <div class="pipeline-line my-1"></div>
                    
                    <div class="grid grid-cols-3 gap-3 w-full">
                        <div class="p-3 bg-black/60 border border-white/10 rounded-xl text-xs text-zinc-400 font-mono">Video Understanding</div>
                        <div class="p-3 bg-black/60 border border-white/10 rounded-xl text-xs text-zinc-400 font-mono">Scene Detection</div>
                        <div class="p-3 bg-black/60 border border-white/10 rounded-xl text-xs text-zinc-400 font-mono">Speech Extraction</div>
                    </div>
                    
                    <div class="pipeline-line my-1"></div>

                    <div class="w-full p-4 bg-purple-900/10 border border-purple-500/30 rounded-2xl font-bold text-sm shadow-[0_0_20px_rgba(139,92,246,0.15)] flex justify-center gap-8 text-purple-300">
                        <span>Research</span> <span>Script Gen</span> <span>Marketing Strategy</span>
                    </div>

                    <div class="pipeline-line my-1"></div>

                    <div class="w-full p-4 bg-blue-900/10 border border-blue-500/30 rounded-2xl font-bold text-sm shadow-[0_0_20px_rgba(59,130,246,0.15)] flex justify-center gap-8 text-blue-300">
                        <span>Thumbnail Gen</span> <span>Social Posts</span> <span>SEO Optimization</span>
                    </div>

                    <div class="pipeline-line my-1"></div>
                    
                    <div class="w-full max-w-xs p-4 bg-gradient-to-r from-purple-600 to-blue-600 border border-white/20 rounded-2xl font-bold text-base text-white shadow-[0_0_30px_rgba(139,92,246,0.4)] flex items-center justify-center gap-3">
                        <i data-lucide="package-check" class="w-5 h-5"></i> Final Content Package
                    </div>
                </div>
                
                <p class="text-xs font-mono text-zinc-500 mt-10 uppercase tracking-widest relative z-10">Fully Autonomous. Powered by Mesh API.</p>
            </div>
        </section>

        <!-- SECTION 6 & 7: MESH ORCHESTRATION & AGENTS -->
        <section class="py-24 px-6 max-w-[1400px] mx-auto w-full">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                
                <!-- Orchestration -->
                <div class="bento-card p-10 md:p-14 reveal flex flex-col items-center justify-center text-center overflow-hidden relative">
                    <span class="vision-badge absolute top-8 left-8">Future Mesh Orchestration</span>
                    <h3 class="text-3xl font-bold tracking-apple text-white mt-8 mb-6">Zero Vendor Lock-in</h3>
                    <p class="text-zinc-400 text-sm mb-10 max-w-sm">MeshFlow X dynamically routes every distinct sub-task to thousands of competing models instantly.</p>
                    
                    <div class="relative w-full h-64 flex items-center justify-center">
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.1)_0,transparent_70%)]"></div>
                        <div class="z-20 w-16 h-16 bg-black border border-white/20 rounded-2xl flex items-center justify-center shadow-[0_0_30px_rgba(59,130,246,0.5)]">
                            <img src="/assets/mesh-logo.png" alt="MeshFlow" class="w-8 h-8 object-contain">
                        </div>
                        
                        <!-- Floating Models -->
                        <div class="absolute top-10 left-10 p-2 bg-white/5 border border-white/10 rounded-lg text-[10px] font-mono text-zinc-300">OpenAI</div>
                        <div class="absolute top-20 right-10 p-2 bg-white/5 border border-white/10 rounded-lg text-[10px] font-mono text-zinc-300">Claude</div>
                        <div class="absolute bottom-10 left-20 p-2 bg-white/5 border border-white/10 rounded-lg text-[10px] font-mono text-zinc-300">DeepSeek</div>
                        <div class="absolute bottom-20 right-20 p-2 bg-white/5 border border-white/10 rounded-lg text-[10px] font-mono text-zinc-300">Gemini</div>
                        <div class="absolute top-4 left-1/2 -translate-x-1/2 p-2 bg-white/5 border border-white/10 rounded-lg text-[10px] font-mono text-zinc-300">Llama</div>
                        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 p-2 bg-white/5 border border-white/10 rounded-lg text-[10px] font-mono text-zinc-300">Mistral</div>
                    </div>
                </div>

                <!-- Agents -->
                <div class="bento-card p-10 md:p-14 reveal delay-100 border-emerald-500/20 bg-emerald-900/5 relative overflow-hidden">
                    <span class="vision-badge absolute top-8 left-8 border-emerald-500/20 bg-emerald-500/10 text-emerald-400">Autonomous Execution</span>
                    <h3 class="text-3xl font-bold tracking-apple text-white mt-8 mb-6">AI Agent Swarms</h3>
                    <p class="text-zinc-400 text-sm mb-10 max-w-sm">Deploy specialized, long-running intelligent workers that collaborate to solve enterprise challenges.</p>
                    
                    <div class="flex flex-wrap gap-3">
                        <% const agents = ['Research Agent', 'Coding Agent', 'Medical Agent', 'Finance Agent', 'Legal Agent', 'Marketing Agent', 'Sales Agent', 'Content Agent', 'Education Agent', 'Security Agent']; %>
                        <% agents.forEach(agent => { %>
                            <div class="px-4 py-2 rounded-xl bg-black/60 border border-emerald-500/30 text-xs font-bold text-emerald-100 shadow-[0_0_15px_rgba(16,185,129,0.15)] flex items-center gap-2">
                                <i data-lucide="bot" class="w-3.5 h-3.5 text-emerald-400"></i> <%= agent %>
                            </div>
                        <% }) %>
                    </div>
                </div>

            </div>
        </section>

        <!-- SECTION 8 & 9 & 10: MISSION CONTROL, KNOWLEDGE GRAPH, FUTURE OF WORK -->
        <section class="py-24 px-6 max-w-[1400px] mx-auto w-full">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 auto-rows-[300px]">
                
                <!-- Mission Control -->
                <div class="bento-card p-8 reveal flex flex-col justify-between group">
                    <div>
                        <span class="vision-badge mb-4">Live Dashboard</span>
                        <h3 class="text-xl font-bold text-white tracking-apple mb-2">Future Mission Control</h3>
                        <p class="text-xs text-zinc-400 leading-relaxed">Live AI collaboration, dynamic routing overrides, cost optimization alerts, and visual execution playback.</p>
                    </div>
                    <div class="w-full h-32 bg-black/50 border border-white/10 rounded-xl overflow-hidden relative">
                        <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-blue-500/20 to-transparent"></div>
                        <!-- Abstract Chart -->
                        <div class="flex items-end justify-between h-full px-4 pb-2 opacity-50 group-hover:opacity-100 transition-opacity">
