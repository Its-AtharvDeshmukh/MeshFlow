// 5. INTELLIGENCE PANEL (MODEL DEBATE DRAWER)
function openIntelligenceDrawer(nodeId) {
    if (!globalState) return;
    const node = globalState.nodes.find(n => n.id === nodeId);
    if (!node || !node.routingAudit) return;

    const drawer = document.getElementById('intelligence-drawer');
    const content = document.getElementById('drawer-content');
    
    document.getElementById('drawer-title').textContent = node.taskName || node.name;
    
    const candidatesHtml = node.routingAudit.candidates.map((c, i) => {
        const isWinner = c.verdict === 'WINNER';
        const barColor = isWinner ? 'bg-blue-500' : 'bg-zinc-600';
        const cardBg = isWinner ? 'bg-blue-500/10 border-blue-500/30' : 'bg-white/[0.02] border-white/5 opacity-70 hover:opacity-100';
        
        return `
        <div class="border rounded-2xl p-5 mb-5 relative overflow-hidden transition-all ${cardBg}">
            ${isWinner ? '<div class="absolute top-0 right-0 px-3 py-1 bg-blue-500 text-white text-[9px] font-bold uppercase tracking-widest rounded-bl-xl shadow-md">Winner</div>' : ''}
            
            <p class="text-[10px] text-zinc-500 font-mono uppercase tracking-widest mb-1">${safeText(c.provider)}</p>
            <div class="flex justify-between items-center mb-6">
                <p class="text-base font-bold text-white break-words pr-2">${safeText(c.model)}</p>
                ${!isWinner ? '<span class="text-[9px] font-bold text-red-400 uppercase tracking-widest bg-red-500/10 px-2.5 py-1 rounded-md border border-red-500/20 shrink-0">Rejected</span>' : ''}
            </div>

            <div class="space-y-4 mb-6">
                <div>
                    <div class="flex justify-between text-[11px] mb-1.5 font-bold">
                        <span class="text-zinc-400 font-mono uppercase tracking-wider">Capability Score</span>
                        <span class="text-white font-mono">${c.overallScore}</span>
                    </div>
                    <div class="w-full bg-black/60 rounded-full h-2 overflow-hidden shadow-inner border border-white/5">
                        <div class="h-full ${barColor} score-bar-fill rounded-full shadow-[0_0_10px_currentColor]" style="width: ${Math.min(100, (c.overallScore / 100000) * 100)}%;"></div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-4 gap-3 text-[10px] font-mono border-t border-white/10 pt-4 mb-4">
                <div class="flex flex-col"><span class="text-zinc-500 uppercase tracking-widest mb-1 font-bold">Logic</span><span class="text-zinc-300 text-xs">${c.reasoningScore}</span></div>
                <div class="flex flex-col"><span class="text-zinc-500 uppercase tracking-widest mb-1 font-bold">Capab.</span><span class="text-zinc-300 text-xs">${c.capabilityScore}</span></div>
                <div class="flex flex-col"><span class="text-zinc-500 uppercase tracking-widest mb-1 font-bold">Speed</span><span class="text-zinc-300 text-xs">${c.latencyScore}</span></div>
                <div class="flex flex-col"><span class="text-zinc-500 uppercase tracking-widest mb-1 font-bold">Econ.</span><span class="text-zinc-300 text-xs">${c.costScore}</span></div>
            </div>
            
            <div class="flex justify-between items-center text-[11px] font-mono border-t border-white/10 pt-4 mt-2">
                <span class="text-zinc-400 font-bold">Latency: <span class="text-white">${c.estimatedLatencyMs}ms</span></span>
                <span class="text-zinc-400 font-bold">Cost: <span class="text-blue-400">$${c.estimatedCostUsd}</span></span>
            </div>
            
            <div class="mt-5 p-4 bg-black/40 rounded-xl border border-white/5 shadow-inner">
                <p class="text-[10px] ${isWinner ? 'text-blue-400' : 'text-zinc-500'} uppercase tracking-widest font-bold mb-2">Architect Reasoning</p>
                <p class="text-[13px] text-zinc-300 leading-relaxed font-sans">${safeText(c.reason)}</p>
            </div>
        </div>`;
    }).join('');

    content.innerHTML = `
        <p class="text-[13px] text-zinc-400 leading-relaxed mb-8">MeshFlow OS evaluated <strong class="text-white">${node.routingAudit.modelsEvaluated} models</strong> in parallel. Below is the decision matrix mapped against task requirements.</p>
        ${candidatesHtml}
        
        <div class="mt-10 mb-6">
            <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4">Complete Node Output</p>
            <div class="bg-black border border-white/10 rounded-2xl p-5 max-h-64 overflow-y-auto custom-scrollbar shadow-inner">
                <p class="text-xs font-mono text-zinc-400 whitespace-pre-wrap leading-relaxed break-words">${safeText(node.output)}</p>
            </div>
        </div>
    `;

    drawer.classList.add('open');
    
    setTimeout(() => {
        const bars = content.querySelectorAll('.score-bar-fill');
        bars.forEach(bar => {
            const w = bar.style.width;
            bar.style.width = '0%';
            setTimeout(() => { bar.style.width = w; }, 50);
        });
    }, 50);
}

function closeIntelligenceDrawer() {
    document.getElementById('intelligence-drawer').classList.remove('open');
}

