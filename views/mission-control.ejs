        modelsGrid.innerHTML = (state.nodes || []).map(n => `
            <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-5 flex flex-col relative overflow-hidden shadow-inner hover:bg-white/5 transition-colors group">
                <div class="flex justify-between items-start mb-4 relative z-10 gap-2">
                    <div class="flex gap-3 items-center min-w-0">
                        <div class="w-9 h-9 rounded-full bg-black border border-white/10 flex items-center justify-center shadow-inner shrink-0"><i data-lucide="cpu" class="w-4 h-4 text-zinc-300"></i></div>
                        <div class="min-w-0">
                            <p class="text-[9px] text-zinc-500 font-mono uppercase tracking-widest mb-0.5 truncate">${safeText(n.provider || n.routing?.provider || 'Auto')}</p>
                            <p class="text-sm font-bold text-white tracking-wide truncate">${safeText(n.apiModel || n.routing?.model || n.model)}</p>
                        </div>
                    </div>
                </div>
                <div class="flex-1 relative z-10 mb-5">
                    <p class="text-[11px] text-zinc-400 leading-relaxed border-l-2 border-blue-500/40 pl-3 py-0.5 bg-gradient-to-r from-blue-500/5 to-transparent">${safeText(n.routing?.reason || n.routingAudit?.winningReason || n.explainability?.why || 'Capability-based route execution.')}</p>
                </div>
                <div class="grid grid-cols-3 gap-2 border-t border-white/5 pt-3 relative z-10">
                    <div class="flex flex-col"><p class="text-[8px] uppercase tracking-widest text-zinc-500 font-bold mb-1">Tokens</p><p class="text-[11px] font-mono text-zinc-300 break-words">${n.tokens || 0}</p></div>
                    <div class="flex flex-col"><p class="text-[8px] uppercase tracking-widest text-zinc-500 font-bold mb-1">Latency</p><p class="text-[11px] font-mono text-zinc-300 break-words">${n.latency || 0}ms</p></div>
                    <div class="flex flex-col"><p class="text-[8px] uppercase tracking-widest text-zinc-500 font-bold mb-1">Cost</p><p class="text-[11px] font-mono text-blue-400 break-words">$${(n.cost || 0).toFixed(4)}</p></div>
                </div>
            </div>
        `).join('');
    }

    lucide.createIcons();
}

function openFinalReportModal() {
    document.getElementById('liquid-modal-backdrop').classList.replace('opacity-0', 'opacity-100');
    document.getElementById('liquid-modal-backdrop').classList.remove('pointer-events-none');
    document.getElementById('liquid-modal').classList.replace('scale-95', 'scale-100');
}

function closeFinalReportModal() {
    document.getElementById('liquid-modal-backdrop').classList.replace('opacity-100', 'opacity-0');
    document.getElementById('liquid-modal-backdrop').classList.add('pointer-events-none');
    document.getElementById('liquid-modal').classList.replace('scale-100', 'scale-95');
}

function switchModalTab(tabId) {
    document.querySelectorAll('.modal-tab').forEach(b => b.classList.remove('border-white', 'text-white', 'text-blue-400', 'text-purple-400', 'active'));
    
    const activeBtn = document.getElementById(`tab-btn-${tabId}`);
    if(activeBtn) {
        if (tabId === 'flow') activeBtn.classList.add('border-b-2', 'border-blue-400', 'text-blue-400', 'active');
        else if (tabId === 'finalout') activeBtn.classList.add('border-b-2', 'border-purple-400', 'text-purple-400', 'active');
        else activeBtn.classList.add('border-white', 'text-white', 'active');
    }
    
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
    
    const targetPane = document.getElementById(`modal-tab-${tabId}`);
    if(targetPane) {
        targetPane.classList.remove('hidden');
    }
}

function getFinalText() {
    if(!globalState || !globalState.finalOutput) return '';
    return globalState.finalOutput.text || (typeof globalState.finalOutput === 'string' ? globalState.finalOutput : '');
}

function downloadPDF() {
    switchModalTab('detailed');
    setTimeout(() => {
        const element = document.getElementById('modal-tab-detailed');
        const opt = { margin: 0.5, filename: 'MeshFlow_OS_Report.pdf', image: { type: 'jpeg', quality: 0.98 }, html2canvas: { scale: 2, backgroundColor: '#09090b' }, jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' } };
        html2pdf().set(opt).from(element).save();
    }, 100);
}

function downloadMarkdown() {
    const blob = new Blob([getFinalText()], { type: 'text/markdown' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'MeshFlow_OS_Report.md'; a.click();
}

function copyReport() {
    navigator.clipboard.writeText(getFinalText());
    alert('Markdown report copied to clipboard.');
}

document.addEventListener('DOMContentLoaded', () => {
    const id = new URLSearchParams(window.location.search).get('id');
    if (id) startPolling(id);
});
</script>
</body>
</html>