<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <%- include('partials/head') %>
  <script src="/js/api-services.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.6/purify.min.js"></script>
  <title>Mission Control | MeshFlow X</title>
  <style>
    :root {
      --bg-black: #000000;
      --panel-bg: rgba(10, 10, 12, 0.6);
      --border-light: rgba(255, 255, 255, 0.08);
    }
    body { background-color: var(--bg-black); color: #ededed; font-family: 'Inter', sans-serif; }
    
    .glass-panel {
      background: var(--panel-bg);
      backdrop-filter: blur(40px);
      -webkit-backdrop-filter: blur(40px);
      border: 1px solid var(--border-light);
      box-shadow: 0 4px 24px -1px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .mesh-grid-bg {
      background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
      background-size: 24px 24px;
    }

    /* Cinematic Glows */
    .glow-bg {
      position: absolute; width: 600px; height: 600px; filter: blur(120px); opacity: 0.15; pointer-events: none; border-radius: 50%;
    }
    .glow-blue { top: -100px; left: -100px; background: #3b82f6; }
    .glow-purple { bottom: -200px; right: -100px; background: #8b5cf6; }

    /* Custom Scrollbars */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }

    /* Self-Healing Flash Animation */
    @keyframes heal-flash {
      0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); border-color: rgba(239, 68, 68, 0.8); }
      50% { box-shadow: 0 0 40px 10px rgba(234, 179, 8, 0.2); border-color: rgba(234, 179, 8, 0.5); }
      100% { box-shadow: 0 0 20px 0px rgba(34, 197, 94, 0.1); border-color: var(--border-light); }
    }
    .animate-heal { animation: heal-flash 2s cubic-bezier(0.4, 0, 0.2, 1) forwards; }

    /* Intelligence Drawer */
    #intelligence-drawer {
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    #intelligence-drawer.open { transform: translateX(0); }
    
    /* Progress Bars */
    .score-bar-fill { transition: width 1s cubic-bezier(0.16, 1, 0.3, 1); }

    /* Output Stream Box */
    .water-output {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(59, 130, 246, 0.2);
        box-shadow: inset 0 0 30px rgba(59, 130, 246, 0.05);
    }
  </style>
</head>
<body class="flex overflow-hidden relative h-screen w-screen">

<!-- Background Ambience -->
<div class="fixed inset-0 z-0 pointer-events-none">
  <div class="absolute inset-0 bg-[#040405]"></div>
  <div class="absolute inset-0 mesh-grid-bg mask-image-[linear-gradient(to_bottom,black,transparent)]"></div>
  <div class="glow-bg glow-blue"></div>
  <div class="glow-bg glow-purple"></div>
</div>

<%- include('partials/sidebar', { currentPath: '/mission-control' }) %>

<div class="flex flex-1 z-10 overflow-hidden md:pl-60 h-full w-full">
    
    <!-- MAIN COMMAND CANVAS -->
    <main class="flex-1 relative flex flex-col overflow-y-auto px-6 md:px-12 py-10 custom-scrollbar h-full w-full">
        
        <div class="max-w-7xl mx-auto w-full">
            <!-- Execution Header -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6 glass-panel p-8 rounded-[24px]">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <div id="mc-pulse" class="w-2.5 h-2.5 rounded-full bg-blue-500 animate-pulse shadow-[0_0_15px_rgba(59,130,246,0.8)]"></div>
                        <p class="text-[11px] text-blue-400 uppercase tracking-widest font-mono font-bold" id="mc-status">Establishing Secure Uplink</p>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white drop-shadow-lg" id="mc-title">Initializing OS</h1>
                </div>
                
                <div class="flex flex-wrap items-end justify-start md:justify-end gap-6 md:gap-10">
                    <div class="text-left md:text-right hidden sm:block">
                        <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono mb-1">Compute Latency</p>
                        <p class="text-3xl font-mono text-zinc-300 font-bold" id="metric-latency">0ms</p>
                    </div>
                    <div class="text-left md:text-right hidden sm:block">
                        <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono mb-1">Network Cost</p>
                        <p class="text-3xl font-mono text-zinc-300 font-bold" id="metric-cost">$0.0000</p>
                    </div>
                    <div class="text-left md:text-right hidden sm:block">
                        <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-mono mb-1">OS Progress</p>
                        <p class="text-3xl font-mono text-blue-400 font-bold" id="mc-progress">0%</p>
                    </div>
                </div>
            </div>

            <!-- Dashboard Grid -->
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-8 pb-12">
                
                <!-- LEFT: Nodes Pipeline -->
                <div class="xl:col-span-2 space-y-6" id="nodes-container">
                    <!-- Nodes injected here via JS -->
                </div>

                <!-- RIGHT: Final Report Panel & Intelligence Feed -->
                <div class="space-y-6 self-start sticky top-0 w-full">
                    
                    <!-- Counterfactual Dashboard triggers here -->
                    <div id="final-output-card" class="w-full transition-all duration-700"></div>
                    
                    <!-- Live Intelligence Feed -->
                    <aside class="w-full border border-white/5 bg-black/60 backdrop-blur-3xl flex flex-col rounded-[24px] overflow-hidden shadow-2xl relative">
                        <div class="p-6 border-b border-white/5 bg-white/[0.02]">
                            <h3 class="text-[11px] font-bold text-zinc-400 uppercase tracking-widest flex items-center gap-2">
                                <i data-lucide="activity" class="w-4 h-4 text-blue-400"></i> OS Intelligence Feed
                            </h3>
                        </div>
                        <div id="intelligence-feed" class="overflow-y-auto p-6 space-y-6 relative custom-scrollbar max-h-[60vh] min-h-[300px]" role="log" aria-live="polite">
                            <div class="text-xs text-zinc-500 flex items-center gap-2 font-mono">
                                <i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i> Awaiting telemetry...
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- OS INTELLIGENCE DRAWER (MODEL DEBATE) -->
<div id="intelligence-drawer" class="fixed top-0 right-0 h-full w-full sm:w-[480px] glass-panel border-l border-white/10 z-[100] flex flex-col shadow-[-30px_0_80px_rgba(0,0,0,0.8)]">
    <div class="p-6 md:p-8 border-b border-white/5 flex justify-between items-center bg-gradient-to-b from-white/[0.05] to-transparent">
        <div>
            <p class="text-[10px] text-blue-400 font-mono uppercase tracking-widest mb-1.5">Model Debate Matrix</p>
            <h2 class="text-xl font-bold text-white tracking-tight" id="drawer-title">Node Intelligence</h2>
        </div>
        <button onclick="closeIntelligenceDrawer()" class="p-2 hover:bg-white/10 rounded-xl transition-colors text-zinc-400 hover:text-white">
            <i data-lucide="x" class="w-6 h-6"></i>
        </button>
    </div>
    <div class="flex-1 overflow-y-auto p-6 md:p-8 custom-scrollbar" id="drawer-content">
        <!-- Debate contents injected via JS -->
    </div>
</div>

<!-- ==========================================
     THE FINAL REPORT MODAL (REDESIGNED TABS)
     ========================================== -->
<div id="liquid-modal-backdrop" class="fixed inset-0 z-[9999] bg-black/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-400 ease-out flex items-center justify-center p-4 md:p-[8vh] md:px-[12vw]">
    <div id="liquid-modal" class="w-full max-w-6xl h-full bg-[#0a0a0c]/95 border border-white/10 rounded-[28px] shadow-2xl flex flex-col scale-95 transition-transform duration-400 overflow-hidden relative">
        <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-white/[0.03] to-transparent pointer-events-none"></div>
        <header class="px-6 md:px-8 pt-8 pb-5 flex flex-col md:flex-row justify-between items-start relative z-10 shrink-0 gap-4">
            <div class="flex gap-5 items-center">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-zinc-800 to-black border border-white/10 flex items-center justify-center shadow-inner relative overflow-hidden shrink-0 hidden sm:flex">
                    <div class="absolute inset-0 bg-white/5 opacity-50"></div>
                    <i data-lucide="layers" class="w-6 h-6 text-white drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]"></i>
                </div>
                <div class="flex flex-col justify-center">
                    <div class="flex items-center gap-2 mb-1.5">
                        <span class="text-[9px] font-mono font-bold text-green-400 bg-green-500/10 px-2 py-0.5 rounded-md border border-green-500/20 flex items-center gap-1 uppercase tracking-widest shadow-[0_0_10px_rgba(74,222,128,0.1)]">
                            <i data-lucide="check-circle-2" class="w-3 h-3"></i> Execution Completed
                        </span>
                        <span class="text-[10px] text-zinc-500 font-mono" id="modal-timestamp"></span>
                    </div>
                    <h1 class="text-2xl font-bold text-white tracking-tight" id="modal-title">Final OS Report</h1>
                </div>
            </div>
            <div class="flex gap-4 md:gap-8 text-right items-center pt-2">
                <div class="flex flex-col items-end">
                    <p class="text-[9px] text-zinc-500 uppercase tracking-widest font-bold mb-1">Confidence</p>
                    <p class="text-base md:text-lg font-mono font-bold text-green-400 drop-shadow-[0_0_8px_rgba(74,222,128,0.2)]" id="modal-confidence">--</p>
                </div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="flex flex-col items-end">
                    <p class="text-[9px] text-zinc-500 uppercase tracking-widest font-bold mb-1">Total Cost</p>
                    <p class="text-base md:text-lg font-mono font-bold text-blue-400" id="modal-cost">--</p>
                </div>
                <div class="w-px h-8 bg-white/10 hidden sm:block"></div>
                <div class="flex flex-col items-end hidden sm:flex">
                    <p class="text-[9px] text-zinc-500 uppercase tracking-widest font-bold mb-1">Processing Time</p>
                    <p class="text-base md:text-lg font-mono font-bold text-zinc-200" id="modal-latency">--</p>
                </div>
            </div>
        </header>
        
        <!-- REDESIGNED TABS (From Code 2) -->
        <div class="px-8 border-b border-white/5 flex gap-6 overflow-x-auto hide-scrollbar bg-black/20 z-10 shrink-0">
            <button onclick="switchModalTab('overview')" id="tab-btn-overview" class="modal-tab active py-4 text-[11px] font-bold text-white border-b-2 border-white transition-all whitespace-nowrap">Overview</button>
            <button onclick="switchModalTab('detailed')" id="tab-btn-detailed" class="modal-tab py-4 text-[11px] font-bold text-zinc-500 border-b-2 border-transparent hover:text-zinc-300 transition-all whitespace-nowrap">Synthesized Report</button>
            <button onclick="switchModalTab('flow')" id="tab-btn-flow" class="modal-tab py-4 text-[11px] font-bold text-blue-400 border-b-2 border-transparent hover:text-blue-300 transition-all whitespace-nowrap">Pipeline Output Flow</button>
            <button onclick="switchModalTab('finalout')" id="tab-btn-finalout" class="modal-tab py-4 text-[11px] font-bold text-purple-400 border-b-2 border-transparent hover:text-purple-300 transition-all whitespace-nowrap">Final AI Output</button>
            <button onclick="switchModalTab('stats')" id="tab-btn-stats" class="modal-tab py-4 text-[11px] font-bold text-zinc-500 border-b-2 border-transparent hover:text-zinc-300 transition-all whitespace-nowrap">Execution Statistics</button>
            <button onclick="switchModalTab('models')" id="tab-btn-models" class="modal-tab py-4 text-[11px] font-bold text-zinc-500 border-b-2 border-transparent hover:text-zinc-300 transition-all whitespace-nowrap">Models Used</button>
        </div>

        <div class="flex-1 overflow-y-auto p-6 md:p-10 relative z-10 custom-scrollbar" id="modal-content-area">
            
            <div id="modal-tab-overview" class="tab-pane block animate-in fade-in duration-300">
                <div class="max-w-3xl">
                    <h2 class="text-xl font-bold text-white mb-4">Workflow Execution Overview</h2>
                    <div id="ext-overview" class="text-sm text-zinc-400 leading-relaxed mb-8 prose prose-invert prose-zinc prose-sm">MeshFlow OS successfully executed the intelligent DAG. The system dynamically routed tasks across the model registry to optimize for required capabilities, cost, and latency.</div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="overview-grid"></div>
                </div>
            </div>

            <div id="modal-tab-detailed" class="tab-pane hidden animate-in fade-in duration-300">
                <div id="markdown-container" class="prose prose-invert prose-sm max-w-4xl font-sans prose-headings:font-bold prose-headings:tracking-tight prose-a:text-blue-400 prose-pre:bg-[#060608] prose-pre:border prose-pre:border-white/10 prose-pre:shadow-inner prose-img:rounded-xl"></div>
            </div>

            <!-- REDESIGNED: Pipeline Flow Tab -->
            <div id="modal-tab-flow" class="tab-pane hidden animate-in fade-in duration-300">
                <div class="max-w-4xl">
                    <h2 class="text-xl font-bold text-white mb-2">Knowledge Progression</h2>
                    <p class="text-xs text-zinc-400 mb-8">Trace the exact payload handoffs moving through the directed acyclic graph (DAG).</p>
                    <div id="ext-pipeline-flow" class="space-y-4 border-l-2 border-white/10 ml-4 pl-6"></div>
                </div>
            </div>
            
            <!-- REDESIGNED: Final AI Output Tab -->
            <div id="modal-tab-finalout" class="tab-pane hidden animate-in fade-in duration-300">
                <div class="max-w-4xl">
                    <h2 class="text-xl font-bold text-white mb-2">Pre-Synthesis Output</h2>
                    <p class="text-xs text-zinc-400 mb-6">The raw output generated by the final execution node before entering the Arbitrator summarization step.</p>
                    <div id="ext-final-ai-output" class="bg-black border border-white/10 p-6 rounded-xl text-xs font-mono text-green-400 whitespace-pre-wrap shadow-inner overflow-x-auto"></div>
                </div>
            </div>

            <div id="modal-tab-stats" class="tab-pane hidden animate-in fade-in duration-300">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6" id="stats-grid"></div>
            </div>
            
            <div id="modal-tab-models" class="tab-pane hidden animate-in fade-in duration-300">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-5" id="models-grid"></div>
            </div>

        </div>

        <footer class="p-4 px-6 md:px-8 border-t border-white/5 bg-black/50 backdrop-blur-2xl flex flex-col md:flex-row justify-between items-center relative z-10 shrink-0 gap-4">
            <div class="flex flex-wrap gap-2 justify-center">
                <button onclick="copyReport()" class="flex items-center gap-2 px-4 py-2.5 bg-white/5 hover:bg-white/10 text-[11px] font-bold rounded-xl border border-white/5 transition-all text-zinc-300"><i data-lucide="copy" class="w-3.5 h-3.5"></i> Copy Markdown</button>
                <button onclick="downloadPDF()" class="flex items-center gap-2 px-4 py-2.5 bg-white/5 hover:bg-white/10 text-[11px] font-bold rounded-xl border border-white/5 transition-all text-zinc-300"><i data-lucide="file-text" class="w-3.5 h-3.5"></i> Export PDF</button>
            </div>
            <div class="flex gap-3 items-center w-full md:w-auto justify-center">
                <button onclick="window.location.href='/builder'" class="flex items-center gap-2 px-6 py-2.5 text-[11px] font-bold rounded-xl transition-all text-blue-400 hover:bg-blue-500/10 border border-blue-500/30"><i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i> Return to Architect</button>
                <button onclick="closeFinalReportModal()" class="px-8 py-2.5 bg-white text-black hover:bg-zinc-200 text-[11px] font-bold rounded-xl transition-all shadow-[0_0_24px_rgba(255,255,255,0.2)] w-full md:w-auto">Close Report</button>
            </div>
        </footer>
    </div>
</div>

<script>
lucide.createIcons();
let pollTimer = null;
let globalState = null;
let isPolling = false;
let displayedEventsCount = 0;
let reportOpened = false;

const safeText = (val) => {
    if (val === null || val === undefined) return '';
    return String(val).replace(/[&<>'"]/g, tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag));
};

const parseHTML = (md) => {
    if (!md) return '';
    const raw = typeof marked.parse === 'function' ? marked.parse(md) : marked(md);
    return typeof DOMPurify !== 'undefined' ? DOMPurify.sanitize(raw) : raw;
};

// Error mapping strictly to backend codes
// In views/mission-control.ejs, update the formatErrorCode map:

const formatErrorCode = (code) => {
    if(!code) return "Execution Failed";
    const map = {
        'VALIDATION_FAILED': 'Validation Failed',
        'DAG_INVALID': 'Dependency Failed',
        'SYNTHESIS_SKIPPED': 'No Output Generated',
        'NODE_FAILED': 'Model Failed',
        'CANCELLED': 'Execution Cancelled',
        'DOCUMENT_NOT_FOUND': 'Document Upload Missing',
        'DOCUMENT_INCOMPLETE': 'Document Payload Too Small',
        'FILE_PARSING_FAILED': 'Binary Parsing Failed',
        'TIMEOUT': 'Mesh Timeout'
    };
    return map[code] || code;
};

async function startPolling(id) {
    if (isPolling) return;
    isPolling = true;
    try {
        const state = await MeshFlowAPI.getState(id);
        globalState = state;
        const currentStatus = (state.status || '').toUpperCase();
        state.status = currentStatus;
        
        updateUI(state);
        
        if (['COMPLETED', 'FAILED', 'CANCELLED'].includes(currentStatus)) {
            if(state.finalOutput || state.counterfactuals) {
                renderFinalOutputCard(state);
                
                // Show Top Action Button
                const topBtn = document.getElementById('top-action-bar');
                if (topBtn) {
                    topBtn.classList.remove('hidden');
                    topBtn.classList.add('block', 'animate-in', 'fade-in', 'duration-700');
                }

                // 4. Final Report Auto-Render exactly once
                if (currentStatus === 'COMPLETED' && !reportOpened) {
                    reportOpened = true;
                    setTimeout(openFinalReportModal, 1500); 
                }
            } else if (currentStatus === 'FAILED') {
                renderFinalOutputCard(state); 
            }
            isPolling = false; return; 
        }
    } catch (err) {
        if (globalState && ['COMPLETED', 'FAILED', 'CANCELLED'].includes(globalState.status)) {
            isPolling = false; return;
        }
        document.getElementById('mc-title').textContent = "Execution Terminated";
        document.getElementById('mc-status').innerHTML = "Connection Expired";
        document.getElementById('mc-pulse').className = "w-2.5 h-2.5 rounded-full bg-red-500 shadow-[0_0_15px_rgba(239,68,68,0.8)]";
        isPolling = false; return;
    }
    
    isPolling = false;
    pollTimer = setTimeout(() => startPolling(id), 1000);
}

window.addEventListener('beforeunload', () => { if (pollTimer) clearTimeout(pollTimer); });

function updateUI(state) {
    // 1. HEADER & GLOBAL METRICS
    document.getElementById('mc-title').textContent = safeText(state.workflowName || 'Execution Stream');
    const isFailed = state.status === 'FAILED';
    const isCompleted = state.status === 'COMPLETED';
    const statusEl = document.getElementById('mc-status');
    const pulse = document.getElementById('mc-pulse');
    const progressEl = document.getElementById('mc-progress');

    if (isCompleted) {
        statusEl.textContent = "Pipeline Finalized";
        statusEl.className = "text-[11px] text-green-400 uppercase tracking-widest font-mono font-bold";
        pulse.className = "w-2.5 h-2.5 rounded-full bg-green-500 shadow-[0_0_15px_rgba(34,197,94,0.8)]";
        progressEl.className = "text-3xl font-mono text-green-400 font-bold";
    } else if (isFailed) {
        statusEl.textContent = "System Failure";
        statusEl.className = "text-[11px] text-red-400 uppercase tracking-widest font-mono font-bold";
        pulse.className = "w-2.5 h-2.5 rounded-full bg-red-500 shadow-[0_0_15px_rgba(239,68,68,0.8)]";
        progressEl.className = "text-3xl font-mono text-red-400 font-bold";
    } else {
        statusEl.textContent = state.status === 'SYNTHESIZING' ? "Synthesizing Final Report..." : "Executing DAG Router...";
        progressEl.className = "text-3xl font-mono text-blue-400 font-bold";
    }
    progressEl.textContent = `${Number(state.progress) || 0}%`;

    const metrics = state.metrics || {};
    document.getElementById('metric-cost').textContent = `$${(Number(metrics.totalCost) || 0).toFixed(4)}`;
    document.getElementById('metric-latency').textContent = `${Number(metrics.totalLatency) || 0}ms`;

    // 2. INTELLIGENCE FEED (Backend Events Only)
    const feed = document.getElementById('intelligence-feed');
    const events = state.intelligenceEvents || [];
    
    if (events.length > displayedEventsCount) {
        const newEvents = events.slice(displayedEventsCount);
        newEvents.forEach(ev => {
            const timeStr = new Date(ev.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'});
            let icon = "info"; let color = "text-zinc-400";
            
            // Map types from backend logic securely
            if(ev.type.includes("FAIL")) { icon = "x-circle"; color = "text-red-400"; }
            else if(ev.type.includes("COMPLETED") || ev.type.includes("SUCCESS")) { icon = "check-circle-2"; color = "text-green-400"; }
            else if(ev.type.includes("FALLBACK")) { icon = "shield-alert"; color = "text-yellow-400"; }
            else if(ev.type.includes("MODEL") || ev.type.includes("ADVISOR")) { icon = "brain-circuit"; color = "text-purple-400"; }
            else if(ev.type.includes("SYNTH") || ev.type.includes("GENERATED")) { icon = "sparkles"; color = "text-blue-400"; }
            else if(ev.type.includes("VALIDATED")) { icon = "check-square"; color = "text-emerald-400"; }
            else if(ev.type.includes("PARSED")) { icon = "file-search"; color = "text-indigo-400"; }

            const el = document.createElement('div');
            el.className = "flex gap-4 items-start animate-in fade-in slide-in-from-bottom-2 duration-500";
            el.innerHTML = `
                <div class="w-8 h-8 rounded-full border border-white/5 bg-white/[0.02] flex items-center justify-center shrink-0">
                    <i data-lucide="${icon}" class="w-4 h-4 ${color}"></i>
                </div>
                <div class="pt-1 w-full break-words">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-[12px] font-bold text-white tracking-wide">${safeText(ev.message)}</span>
                        <span class="text-[9px] font-mono text-zinc-600 shrink-0 ml-2">${timeStr}</span>
                    </div>
                    ${(ev.provider && ev.model) ? `<p class="text-[10px] font-mono text-blue-400/90 mt-0.5">${safeText(ev.provider)} / ${safeText(ev.model)}</p>` : ''}
                    ${ev.reason ? `<p class="text-[10px] text-zinc-400 mt-1 italic leading-relaxed border-l border-zinc-700 pl-2 py-0.5">${safeText(ev.reason)}</p>` : ''}
                    ${ev.durationMs ? `<p class="text-[9px] font-mono text-zinc-600 mt-0.5">${ev.durationMs}ms compute</p>` : ''}
                </div>
            `;
            feed.appendChild(el);
        });
        displayedEventsCount = events.length;
        lucide.createIcons();
        feed.scrollTop = feed.scrollHeight;
    }

    // 3. MAIN NODES PIPELINE (Strict JSON match to backend schema)
    // SORTED BY DEPENDENCIES TO RENDER LINEARLY
    const rawNodes = state.nodes || [];
    const nodes = [...rawNodes].sort((a,b) => (a.dependencies?.length || 0) - (b.dependencies?.length || 0));
    
    const container = document.getElementById('nodes-container');
    
    if (nodes.length > 0) {
        container.innerHTML = nodes.map(node => {
            const status = (node.status || '').toUpperCase();
            const isFallback = node.fallbackActivated === true;
            
            let borderClass = 'border-white/5 bg-white/[0.02]';
            let statusBadge = '<span class="text-[10px] font-mono font-bold text-zinc-500 uppercase tracking-widest">Pending Route</span>';
            let outputText = 'Awaiting execution...';
            
            if (status === 'RUNNING') {
                borderClass = 'border-blue-500/30 bg-blue-900/10 ring-1 ring-blue-500/20 shadow-[0_0_30px_rgba(59,130,246,0.1)]';
                statusBadge = '<span class="text-[10px] font-mono font-bold text-blue-400 uppercase flex items-center gap-1.5"><i data-lucide="loader-2" class="w-3 h-3 animate-spin"></i> Processing</span>';
                outputText = '<span class="text-blue-400 animate-pulse font-mono">Analyzing semantic graph...</span>';
            } else if (status === 'COMPLETED') {
                borderClass = 'border-white/10 bg-black/40 hover:bg-white/[0.04] transition-colors cursor-pointer';
                statusBadge = '<span class="text-[10px] font-mono font-bold text-green-400 uppercase flex items-center gap-1.5"><i data-lucide="check" class="w-3 h-3"></i> Success</span>';
                outputText = node.output ? safeText(node.output).substring(0, 140) + '...' : 'Data processed.';
            } else if (status === 'FAILED') {
                borderClass = 'border-red-500/20 bg-red-950/20';
                statusBadge = '<span class="text-[10px] font-mono font-bold text-red-400 uppercase flex items-center gap-1.5"><i data-lucide="x" class="w-3 h-3"></i> Failed</span>';
                outputText = `<span class="text-red-400">${safeText(node.error?.reason || 'Node execution failed.')}</span>`;
            }

            // Routing logic strictly aligns with node.routing and node.routingAudit
            const providerName = node.provider || node.routing?.provider || 'Auto';
            const modelName = node.apiModel || node.routing?.model || 'Pending';
            
            let modelVisual = `<p class="text-[10px] font-mono text-zinc-400 mt-1">${safeText(providerName)} / <span class="text-white">${safeText(modelName)}</span></p>`;
            
            // Self-Healing Representation
            if (isFallback && status === 'COMPLETED' && node.attemptHistory && node.attemptHistory.length > 1) {
                borderClass += ' animate-heal';
                const failedAttempt = node.attemptHistory[0];
                const successAttempt = node.attemptHistory[node.attemptHistory.length - 1];
                
                statusBadge = '<span class="text-[10px] font-mono font-bold text-yellow-400 uppercase flex items-center gap-1.5"><i data-lucide="shield-alert" class="w-3 h-3"></i> Auto-Healed</span>';
                
                modelVisual = `
                    <div class="flex items-center gap-2 mt-1">
                        <span class="text-[10px] font-mono text-red-400 line-through opacity-70">${safeText(failedAttempt.model)}</span>
                        <i data-lucide="arrow-right" class="w-3 h-3 text-zinc-500"></i>
                        <span class="text-[10px] font-mono text-green-400 font-bold">${safeText(successAttempt.model)}</span>
                    </div>
                `;
            }

            const latencyVal = node.latency !== undefined ? `${node.latency}ms` : '--';
            const costVal = node.cost !== undefined ? `$${node.cost.toFixed(4)}` : '--';
            const tokensVal = node.tokens !== undefined ? node.tokens : '--';

            const metricsHtml = (status === 'COMPLETED' || node.latency > 0) ? `
                <div class="flex items-center gap-4 text-right shrink-0">
                    <div class="hidden sm:block">
                        <p class="text-[9px] uppercase tracking-widest text-zinc-500 mb-0.5">Latency</p>
                        <p class="text-xs font-mono text-zinc-300">${latencyVal}</p>
                    </div>
                    <div class="hidden sm:block">
                        <p class="text-[9px] uppercase tracking-widest text-zinc-500 mb-0.5">Cost</p>
                        <p class="text-xs font-mono text-zinc-300">${costVal}</p>
                    </div>
                    <div class="hidden sm:block">
                        <p class="text-[9px] uppercase tracking-widest text-zinc-500 mb-0.5">Tokens</p>
                        <p class="text-xs font-mono text-zinc-300">${tokensVal}</p>
                    </div>
                    ${status === 'COMPLETED' ? `
                    <button class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center bg-white/5 hover:bg-white/10 text-white transition-colors ml-2" title="View OS Intelligence">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>` : ''}
                </div>` : '';

            return `
            <div class="w-full glass-panel rounded-[20px] p-5 relative overflow-hidden ${borderClass}" ${status === 'COMPLETED' ? `onclick="openIntelligenceDrawer('${node.id}')"` : ''}>
                <div class="flex justify-between items-start gap-4">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-1">
                            <h3 class="text-sm font-bold text-white tracking-tight">${safeText(node.taskName || node.name)}</h3>
                            ${statusBadge}
                        </div>
                        ${modelVisual}
                        <p class="text-xs text-zinc-400 mt-3 truncate leading-relaxed max-w-[85%]">${outputText}</p>
                    </div>
                    ${metricsHtml}
                </div>
            </div>`;
        }).join('');
        lucide.createIcons();
    }
}

