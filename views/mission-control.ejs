function populateModalData(state) {
    if (!state) return;

    // Header Updates
    const titleEl = document.getElementById('modal-title');
    if(titleEl) titleEl.textContent = safeText(state.workflowName || 'Final OS Report');
    
    const latEl = document.getElementById('modal-latency');
    if(latEl) latEl.textContent = `${state.metrics?.totalLatency || 0}ms`;
    
    const costEl = document.getElementById('modal-cost');
    if(costEl) costEl.textContent = `$${(state.metrics?.totalCost || 0).toFixed(4)}`;
    
    const confidences = (state.nodes || [])
        .map(n => parseFloat(n.explainability?.estimatedConfidence || n.routingAudit?.confidence || n.routing?.confidence))
        .filter(v => !isNaN(v));
    const avgConfidence = confidences.length ? (confidences.reduce((a, b) => a + b, 0) / confidences.length).toFixed(1) : null;
    
    const confEl = document.getElementById('modal-confidence');
    if(confEl) confEl.textContent = avgConfidence !== null ? `${avgConfidence}%` : '--';

    // 1. Synthesized Report (Markdown)
    const mdContainer = document.getElementById('markdown-container');
    if(mdContainer) mdContainer.innerHTML = parseHTML(state.finalOutput?.text || '');
    
    // 2. Final AI Output (Raw Pipeline Data)
    const finalOutContainer = document.getElementById('ext-final-ai-output');
    if(finalOutContainer) finalOutContainer.textContent = state.finalOutput?.rawPipelineData || state.finalOutput?.finalNodeOutput || "No pre-synthesis data available.";
    
    // 3. Pipeline Output Flow (Nodes sequence)
    const flowContainer = document.getElementById('ext-pipeline-flow');
    if(flowContainer) {
        // Sort flow to ensure chronological dependency mapping
        const rawNodes = state.nodes || [];
        const flow = [...rawNodes].sort((a,b) => (a.dependencies?.length || 0) - (b.dependencies?.length || 0));
        
