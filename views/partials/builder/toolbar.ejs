<!-- views/partials/builder/toolbar.ejs -->
<header class="h-16 border-b border-white/5 flex items-center justify-between px-6 bg-[#0a0a0c]/80 backdrop-blur-2xl shrink-0 z-20 shadow-[0_4px_24px_rgba(0,0,0,0.4)]">
  <div class="flex items-center gap-6">
    <div class="flex items-center gap-3">
        <div class="w-8 h-8 flex items-center justify-center">
            <img src="/assets/mesh-logo.png" alt="MeshFlow X" class="w-full h-full object-contain">
        </div>
        <input type="text" id="workflow-name" value="Intelligent OS Pipeline" class="bg-transparent text-lg font-bold text-white focus:outline-none border-b border-transparent focus:border-blue-500 w-64 transition-colors tracking-tight placeholder-zinc-600">
    </div>
    <div class="flex items-center gap-2 ml-4 border-l border-white/10 pl-6 hidden md:flex">
        <div class="relative group">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-lg blur opacity-20 group-focus-within:opacity-50 transition duration-500"></div>
            <div class="relative flex items-center bg-black/50 border border-white/10 rounded-lg overflow-hidden">
                <i data-lucide="sparkles" class="w-3.5 h-3.5 text-blue-400 ml-3"></i>
                <input type="text" id="ai-prompt-input" placeholder="Prompt OS Architect..." class="bg-transparent text-xs px-3 py-2 w-72 focus:outline-none text-white placeholder-zinc-500 font-mono tracking-wide">
                <button type="button" id="btn-generate" class="text-xs bg-white/5 hover:bg-blue-500/20 text-zinc-300 hover:text-blue-400 px-4 py-2 transition-colors border-l border-white/10 font-bold tracking-widest uppercase">
                    Generate
                </button>
            </div>
        </div>
    </div>
  </div>
  <div class="flex items-center gap-4">
    <!-- FIX: type="button" prevents the page from randomly reloading/redirecting to the home page -->
    <button type="button" id="btn-optimize" onclick="BuilderEngine.applyOptimization()" class="hidden text-[10px] font-bold tracking-widest uppercase bg-purple-500/10 hover:bg-purple-500/20 text-purple-400 border border-purple-500/30 px-4 py-2 rounded-lg transition-all shadow-[0_0_15px_rgba(168,85,247,0.15)] flex items-center gap-2">
        <i data-lucide="wand-2" class="w-3.5 h-3.5"></i> Optimize Route
    </button>
    
    <button type="button" id="btn-run-workflow" onclick="BuilderEngine.executeWorkflow()" disabled class="group relative inline-flex items-center justify-center gap-2 px-6 py-2.5 font-bold text-white bg-blue-600 rounded-xl overflow-hidden transition-all hover:scale-105 shadow-[0_0_20px_rgba(37,99,235,0.4)] disabled:opacity-50 disabled:pointer-events-none disabled:hover:scale-100 disabled:shadow-none disabled:bg-zinc-800 disabled:text-zinc-500">
        <span class="absolute inset-0 w-full h-full bg-gradient-to-br from-blue-400 via-blue-600 to-purple-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
        <i data-lucide="play" class="w-3.5 h-3.5 relative z-10 group-disabled:hidden"></i>
        <span class="relative z-10 text-[11px] tracking-widest uppercase">Deploy OS</span>
    </button>
  </div>
</header>