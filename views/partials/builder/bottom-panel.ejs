<!-- views/partials/builder/bottom-panel.ejs -->
<div class="h-48 border-t border-white/5 bg-[#0a0a0c]/90 backdrop-blur-2xl flex flex-col shrink-0 z-20">
    <div class="px-6 h-10 border-b border-white/5 bg-white/[0.02] flex justify-between items-center text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
        <div class="flex items-center gap-2">
            <i data-lucide="terminal" class="w-3.5 h-3.5 text-blue-400"></i> OS Execution Console
        </div>
        <button onclick="document.getElementById('console-output').innerHTML=''" class="hover:text-white transition-colors flex items-center gap-1.5 bg-white/5 hover:bg-red-500/20 hover:text-red-400 hover:border-red-500/30 px-2.5 py-1 rounded border border-white/10" title="Clear Console">
            <i data-lucide="trash-2" class="w-3 h-3"></i> Clear
        </button>
    </div>
    
    <div id="console-output" class="p-4 px-6 text-[11px] font-mono text-zinc-400 flex-1 overflow-y-auto custom-scrollbar">
        <!-- Initial Boot Log -->
        <div class="flex gap-2 items-start p-2.5 rounded-xl bg-white/[0.02] border border-white/5 mb-2 shadow-inner">
            <i data-lucide="check-circle-2" class="w-4 h-4 mt-0.5 text-green-400"></i>
            <div>
                <p class="text-[10px] font-mono text-zinc-500 mb-0.5"><span id="boot-time-display"></span> [BOOT]</p>
                <p class="text-xs text-zinc-300 leading-relaxed font-sans">MeshFlow OS initialized. Awaiting architectural instructions.</p>
            </div>
        </div>
    </div>
</div>
<script>
    document.getElementById('boot-time-display').textContent = new Date().toLocaleTimeString();
</script>