<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <%- include('partials/head') %>
  <script src="/js/api-services.js"></script>
  <title>History | MeshFlow X</title>
</head>
<body class="bg-black text-white h-screen w-screen flex overflow-hidden">
  <%- include('partials/sidebar', { currentPath: '/history' }) %>

  <main class="flex-1 overflow-y-auto p-12 pl-72 bg-[#060607]">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl font-bold mb-2">Execution History</h1>
      <p class="text-zinc-500 text-sm mb-10">Review, replay, and audit previous Mesh API executions.</p>

      <div class="bg-zinc-950 border border-zinc-800 rounded-xl overflow-hidden shadow-2xl">
        <table class="w-full text-left text-sm">
          <thead class="bg-zinc-900 border-b border-zinc-800 text-zinc-400 text-xs uppercase tracking-wider">
            <tr>
              <th class="px-6 py-4 font-medium">Workflow</th>
              <th class="px-6 py-4 font-medium">Status</th>
              <th class="px-6 py-4 font-medium">Cost</th>
              <th class="px-6 py-4 font-medium">Date</th>
              <th class="px-6 py-4 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody id="history-rows" class="divide-y divide-zinc-800/50">
             <tr><td colspan="5" class="p-10 text-center"><i data-lucide="loader-2" class="w-6 h-6 animate-spin mx-auto text-zinc-500"></i></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    lucide.createIcons();

    async function loadHistory() {
      const container = document.getElementById('history-rows');
      try {
        const history = await MeshFlowAPI.getHistory();
        
        if (!history || history.length === 0) {
          container.innerHTML = `<tr><td colspan="5" class="p-16 text-center text-zinc-500">
            <i data-lucide="database" class="w-8 h-8 mx-auto mb-3 opacity-50"></i>
            <p>No executions found in the database.</p>
            <a href="/builder" class="text-blue-500 hover:text-blue-400 mt-4 inline-block">Build your first workflow</a>
          </td></tr>`;
          lucide.createIcons();
          return;
        }

        container.innerHTML = history.map(run => `
          <tr class="hover:bg-zinc-900/50 transition-colors group">
            <td class="px-6 py-4 font-medium text-white">${run.workflowName || 'Automated Workflow'}</td>
            <td class="px-6 py-4">
               <span class="px-2 py-1 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider ${run.status === 'COMPLETED' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-red-500/10 text-red-400 border border-red-500/20'}">${run.status}</span>
            </td>
            <td class="px-6 py-4 font-mono text-zinc-400">$${(run.metrics?.totalCost || run.totalCost || 0).toFixed(4)}</td>
            <td class="px-6 py-4 text-zinc-500">${new Date(run.timestamp || run.createdAt).toLocaleString()}</td>
            <td class="px-6 py-4 text-right opacity-0 group-hover:opacity-100 transition-opacity">
               <button onclick="replayRun('${run.executionId}')" class="text-blue-400 hover:text-blue-300 text-xs font-semibold mr-4"><i data-lucide="play" class="w-3 h-3 inline mr-1"></i>Replay</button>
               <button onclick="deleteRun('${run.executionId}')" class="text-red-400 hover:text-red-300"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
            </td>
          </tr>
        `).join('');
        lucide.createIcons();
      } catch (err) {
        container.innerHTML = `<tr><td colspan="5" class="p-6 text-center text-red-400">Error loading data. Is the database connected?</td></tr>`;
      }
    }

    async function deleteRun(id) {
      if (!confirm('Permanently delete this execution?')) return;
      await MeshFlowAPI.deleteHistory(id).catch(e => alert(e.message));
      loadHistory();
    }

   // Inside history.ejs
async function replayRun(id) {
    try {
        const res = await MeshFlowAPI.replay(id);
        if (res.success && res.executionId) {
            window.location.href = `/mission-control?id=${res.executionId}`;
        } else {
            throw new Error("Invalid replay response.");
        }
    } catch(err) { alert(`Replay failed: ${err.message}`); }
}

    document.addEventListener('DOMContentLoaded', loadHistory);

    async function downloadRun(id) {
        try {
            const res = await MeshFlowAPI.request(`/api/history/${id}`);
            const dataStr = JSON.stringify(res.data, null, 2);
            const blob = new Blob([dataStr], { type: "application/json" });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `meshflow-execution-${id}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        } catch (err) {
            alert(`Failed to download execution data: ${err.message}`);
        }
    }
  </script>
</body>
</html>