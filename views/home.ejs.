                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Characters</span><span id="doc-meta-chars" class="text-[11px] text-zinc-300 font-mono">--</span></div>
