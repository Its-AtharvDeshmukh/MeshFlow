    </section>

    <form id="master-generate-form">
      <!-- HIDDEN INPUT FOR DOCUMENT ID -->
      <input type="hidden" id="verified-document-id" name="documentId" value="" />
      
      <section class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-8">
        
        <div class="lg:col-span-3">
          
          <!-- DEFAULT DROPZONE -->
          <div id="dropzone" class="dropzone border border-white/10 h-full min-h-[340px] flex flex-col items-center justify-center text-center px-8 py-10 cursor-pointer">
            <div class="dropzone-border"></div>

            <div class="upload-icon-wrap w-16 h-16 rounded-2xl flex items-center justify-center mb-5"
                 style="background:linear-gradient(135deg, rgba(94,234,212,0.15), rgba(139,124,246,0.15)); border:1px solid var(--border-strong);">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 16V4M12 4L7 9M12 4l5 5"/>
                <path d="M4 16v3a2 2 0 002 2h12a2 2 0 002-2v-3"/>
              </svg>
            </div>

            <h2 class="font-display text-2xl font-semibold mb-2">Drop your files here</h2>
            <p class="text-sm text-[var(--text-muted)] mb-6">or browse from your device — we'll detect the format automatically</p>

            <div class="flex flex-wrap items-center justify-center gap-2 mb-7">
              <span class="file-chip font-mono text-[11px] px-2.5 py-1 rounded-md border border-white/10 text-[var(--text-faint)]">PDF</span>
              <span class="file-chip font-mono text-[11px] px-2.5 py-1 rounded-md border border-white/10 text-[var(--text-faint)]">DOCX</span>
              <span class="file-chip font-mono text-[11px] px-2.5 py-1 rounded-md border border-white/10 text-[var(--text-faint)]">CSV</span>
              <span class="file-chip font-mono text-[11px] px-2.5 py-1 rounded-md border border-white/10 text-[var(--text-faint)]">TXT</span>
            </div>

            <button type="button" id="browse-btn" class="btn-browse px-5 py-2.5 rounded-lg border border-white/15 bg-white/[0.03] text-sm font-medium">
              Browse Files
            </button>
            <input type="file" id="file-input" name="file" class="hidden" accept=".pdf,.docx,.csv,.txt" />

            <p id="file-status" class="mt-4 text-xs font-mono text-[var(--cyan)] hidden"></p>
          </div>

          <!-- VERIFIED DOCUMENT READY PANEL -->
          <div id="document-ready-panel" class="hidden dropzone border border-green-500/30 bg-green-900/5 h-full min-h-[340px] flex flex-col items-center justify-center p-6 w-full shadow-[0_0_30px_rgba(34,197,94,0.1)]">
              <div class="w-12 h-12 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center mb-4 border border-green-500/30">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><path d="M14 3v5h5M16 13H8M16 17H8M10 9H8"/></svg>
              </div>
              <h3 class="font-display font-semibold text-xl text-white mb-1">📄 Document Ready</h3>
              <p id="doc-meta-name" class="text-xs font-mono text-zinc-400 mb-5">fileName.pdf</p>
              
              <div class="grid grid-cols-2 gap-x-8 gap-y-3 text-left w-full max-w-sm mb-6">
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Status</span><span class="text-[11px] text-green-400 font-mono">✓ Uploaded</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Extraction</span><span class="text-[11px] text-green-400 font-mono">✓ Successful</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Pages</span><span id="doc-meta-pages" class="text-[11px] text-zinc-300 font-mono">--</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Words</span><span id="doc-meta-words" class="text-[11px] text-zinc-300 font-mono">--</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Characters</span><span id="doc-meta-chars" class="text-[11px] text-zinc-300 font-mono">--</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">Language</span><span id="doc-meta-lang" class="text-[11px] text-zinc-300 font-mono">--</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">File Type</span><span id="doc-meta-type" class="text-[11px] text-zinc-300 font-mono">--</span></div>
                  <div class="flex justify-between border-b border-white/5 pb-1"><span class="text-[10px] text-zinc-500 uppercase tracking-wider font-bold">OCR</span><span id="doc-meta-ocr" class="text-[11px] text-zinc-300 font-mono">--</span></div>
              </div>
              
              <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-500/10 border border-green-500/20 rounded text-[11px] text-green-400 font-bold uppercase tracking-widest shadow-inner">
                  Ready for AI Workflow <i data-lucide="check-circle-2" class="w-3.5 h-3.5"></i>
              </div>
          </div>
        </div>

        <div class="lg:col-span-2 flex flex-col gap-4">
          <div class="composer flex-1 rounded-2xl border border-white/10 bg-[var(--bg-elevated)] p-5 flex flex-col">
            <label for="prompt-textarea" class="text-xs font-mono text-[var(--text-faint)] mb-2 uppercase tracking-wide">Describe the workflow</label>
            <textarea
              id="prompt-textarea"
              name="prompt"
              rows="3"
              required
              placeholder="e.g. Summarize this contract and flag any unusual clauses…"
              class="w-full bg-transparent outline-none text-[15px] leading-relaxed placeholder:text-[var(--text-faint)] mb-4"
            ></textarea>

            <div class="flex flex-wrap gap-2 mt-auto">
              <button type="button" class="prompt-chip px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.02] text-xs font-medium text-[var(--text-muted)]" data-prompt="Summarize Document">Summarize Document</button>
              <button type="button" class="prompt-chip px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.02] text-xs font-medium text-[var(--text-muted)]" data-prompt="Analyze Invoice">Analyze Invoice</button>
              <button type="button" class="prompt-chip px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.02] text-xs font-medium text-[var(--text-muted)]" data-prompt="Generate Report">Generate Report</button>
              <button type="button" class="prompt-chip px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.02] text-xs font-medium text-[var(--text-muted)]" data-prompt="Research Topic">Research Topic</button>
            </div>
          </div>

          <button type="submit" id="generate-btn" class="cta-generate w-full py-4 rounded-2xl font-display font-semibold text-[15px] text-[#0B0E14] flex items-center justify-center gap-2">
            <span id="cta-label">✨ Generate AI Workflow</span>
          </button>
        </div>
      </section>
    </form>

    <section class="mb-12">
      <div class="rounded-2xl border border-white/10 bg-[var(--bg-elevated)] p-6 md:p-8">
        <div class="flex items-center justify-between mb-6">
          <h3 class="font-display font-semibold text-lg">AI Workflow Preview</h3>
          <span id="preview-status" class="font-mono text-xs text-[var(--text-faint)]">idle</span>
        </div>

        <div id="preview-empty" class="py-10 text-center">
          <p class="text-[var(--text-muted)] text-sm">No workflow generated yet — drop a file and describe what you need above.</p>
        </div>

        <div id="preview-mesh" class="hidden flex-col md:flex-row items-stretch md:items-center gap-3 md:gap-2">
        </div>
      </div>
    </section>

    <section>
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-display font-semibold text-lg">Recent Workflows</h3>
        <a href="/history" class="text-xs font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">View all →</a>
      </div>

      <div id="recent-workflows" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
        <div class="skeleton rounded-2xl border border-white/10 h-[132px]"></div>
        <div class="skeleton rounded-2xl border border-white/10 h-[132px]"></div>
        <div class="skeleton rounded-2xl border border-white/10 h-[132px]"></div>
      </div>
    </section>

  </main>

<script>
    lucide.createIcons();

    // ---------- Ambient particles ----------
    (function(){
      const container = document.getElementById('mesh-particles');
      const count = window.innerWidth < 768 ? 10 : 20;
      for(let i=0;i<count;i++){
        const p = document.createElement('div');
        p.className = 'mesh-node';
        p.style.top = Math.random()*100 + '%';
        p.style.left = Math.random()*100 + '%';
        p.style.animationDelay = (Math.random()*6) + 's';
        p.style.animationDuration = (7 + Math.random()*6) + 's';
        if(i % 3 === 0){ p.style.background = 'var(--violet)'; p.style.boxShadow = '0 0 8px 2px rgba(139,124,246,0.5)'; }
        container.appendChild(p);
      }
    })();

    // ---------- Dropzone & Document Verification Gate ----------
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('file-input');
    const browseBtn = document.getElementById('browse-btn');
    const fileStatus = document.getElementById('file-status');
    const generateBtn = document.getElementById('generate-btn');
    const masterForm = document.getElementById('master-generate-form');
    
    // HARD DISABLE INITIALLY - Await verification gate
    generateBtn.disabled = true; 

    browseBtn.addEventListener('click', (e) => { e.stopPropagation(); fileInput.click(); });
    dropzone.addEventListener('click', () => fileInput.click());

    ['dragenter','dragover'].forEach(evt => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault(); e.stopPropagation();
        dropzone.classList.add('drag-over');
      });
    });
    ['dragleave','drop'].forEach(evt => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault(); e.stopPropagation();
        if(evt === 'dragleave' && e.target !== dropzone) return;
        dropzone.classList.remove('drag-over');
      });
    });

    dropzone.addEventListener('drop', (e) => {
      const files = e.dataTransfer.files;
      if(files && files.length > 0) {
        const dt = new DataTransfer();
        dt.items.add(files[0]);
        fileInput.files = dt.files;
        fileInput.dispatchEvent(new Event('change')); // Trigger Verification
      }
    });

    fileInput.addEventListener('change', async () => {
        if(!fileInput.files.length) return;
        const file = fileInput.files[0];
        
        fileStatus.innerHTML = '<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin inline-block align-middle"></i> Verifying Document...';
        fileStatus.classList.remove('hidden');
        fileStatus.classList.replace('text-[var(--red)]', 'text-[var(--cyan)]');
        lucide.createIcons();

        const fd = new FormData();
        fd.append('file', file);

        try {
            const response = await fetch('/api/validate-document', { method: 'POST', body: fd });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Validation failed');
            }

            if (data.warning === "DOCUMENT_TOO_SHORT") {
                const proceed = confirm(`The uploaded document appears incomplete (${data.textLength} characters). Do you want to continue?`);
                if (!proceed) {
                    fileInput.value = '';
                    fileStatus.classList.add('hidden');
                    return;
                }
            }

            // Display Document Ready Panel
            document.getElementById('dropzone').classList.add('hidden');
            const readyPanel = document.getElementById('document-ready-panel');
            readyPanel.classList.remove('hidden');
            readyPanel.classList.add('flex', 'animate-in', 'fade-in', 'zoom-in-95', 'duration-500');
            
            // Populate Metadata
            document.getElementById('verified-document-id').value = data.documentId;
            document.getElementById('doc-meta-name').textContent = data.metadata.name;
            document.getElementById('doc-meta-pages').textContent = data.metadata.pages;
            document.getElementById('doc-meta-words').textContent = data.metadata.words;
            document.getElementById('doc-meta-chars').textContent = data.metadata.chars;
            document.getElementById('doc-meta-lang').textContent = data.metadata.language;
            document.getElementById('doc-meta-type').textContent = data.metadata.fileType;
            document.getElementById('doc-meta-ocr').textContent = data.metadata.ocr;
            
            // UNLOCK WORKFLOW GENERATION
            generateBtn.disabled = false;
            generateBtn.classList.add('shadow-[0_0_30px_rgba(94,234,212,0.4)]');

        } catch (err) {
            fileStatus.innerHTML = `<i data-lucide="alert-triangle" class="w-3.5 h-3.5 inline-block align-middle"></i> ${err.message}`;
            fileStatus.classList.replace('text-[var(--cyan)]', 'text-[var(--red)]');
            generateBtn.disabled = true;
            lucide.createIcons();
        }
    });

    // ---------- Auto-growing textarea ----------
    const textarea = document.getElementById('prompt-textarea');
    const composer = textarea.closest('.composer');
    
    function autoGrow(){
      textarea.style.height = 'auto';
      // FIX: Removed 260px limit. The textarea will now infinitely expand based on user input.
      textarea.style.height = textarea.scrollHeight + 'px';
    }
    textarea.addEventListener('input', autoGrow);
    textarea.addEventListener('focus', () => composer.classList.add('is-focused'));
    textarea.addEventListener('blur', () => composer.classList.remove('is-focused'));
    autoGrow();

    // ---------- Prompt chips ----------
    document.querySelectorAll('.prompt-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const examples = {
          'Summarize Document': 'Summarize this document into 5 key bullet points.',
          'Analyze Invoice': 'Extract line items, totals, and flag discrepancies in this invoice.',
          'Generate Report': 'Turn this data into a structured executive report.',
          'Research Topic': 'Research this topic and compile the top findings with sources.'
        };
        textarea.value = examples[chip.dataset.prompt] || chip.dataset.prompt;
        textarea.focus();
        autoGrow();
      });
    });

    // ---------- Generate CTA + Mesh preview ----------
    const ctaLabel = document.getElementById('cta-label');
    const previewEmpty = document.getElementById('preview-empty');
    const previewMesh = document.getElementById('preview-mesh');
    const previewStatus = document.getElementById('preview-status');
    const stages = ['Upload','OCR','Summarize','Reason','Export'];
    
    function buildMesh(stageArray = stages){
      previewMesh.innerHTML = '';
      previewMesh.classList.remove('hidden');
      previewMesh.classList.add('flex');
      
      stageArray.forEach((stage, i) => {
        const node = document.createElement('div');
        node.className = 'mesh-node-box flex-1 min-w-[110px] rounded-xl border border-white/10 bg-[var(--bg-elevated-2)] py-4 text-center';
        node.innerHTML = '<p class="text-[10px] font-mono text-[var(--text-faint)] mb-1">0' + (i+1) + '</p>' +
                          '<p class="font-display font-semibold text-sm truncate px-2">' + stage + '</p>';
        previewMesh.appendChild(node);
        
        if(i < stageArray.length - 1){
          const connector = document.createElement('div');
          connector.className = 'mesh-connector';
          previewMesh.appendChild(connector);
        }
      });
    }

    function animateMesh(){
      const nodes = previewMesh.querySelectorAll('.mesh-node-box');
      const connectors = previewMesh.querySelectorAll('.mesh-connector');
      nodes.forEach((node, i) => {
        setTimeout(() => {
          node.classList.add('revealed');
          node.classList.add('active-pulse');
          setTimeout(() => node.classList.remove('active-pulse'), 700);
          if(connectors[i]){
            setTimeout(() => connectors[i].classList.add('pulse'), 350);
          }
        }, i * 450);
      });
    }

    // ---------- Master API Integration ----------
// Add this AbortController to your Master API Integration block
masterForm.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (generateBtn.disabled) return;

    // Add a timeout for the frontend fetch
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 50000); // 50s timeout

    generateBtn.disabled = true;
    ctaLabel.innerHTML = '<span class="spinner"></span> Architecting...';
    
    try {
        const response = await fetch('/api/generate-workflow', { 
            method: 'POST', 
            body: new FormData(masterForm),
            signal: controller.signal // Attaches the timeout
        });
        
        const workflowData = await response.json();
        if (!response.ok) throw new Error(workflowData.error || "Server failed");
        
        localStorage.setItem('meshWorkflow', JSON.stringify(workflowData.workflow || workflowData));
        window.location.href = '/builder';
    } catch (error) {
        alert("Generation Error: " + (error.name === 'AbortError' ? 'Server took too long.' : error.message));
        ctaLabel.textContent = '  Generate AI Workflow';
        generateBtn.disabled = false;
    } finally {
        clearTimeout(timeoutId);
    }
});
    // ---------- Recent workflows (live data) ----------
    const STATUS_STYLES = {
      COMPLETED: { dot: 'bg-emerald-400', text: 'text-emerald-400' },
      FAILED:    { dot: 'bg-[var(--red)]', text: 'text-[var(--red)]' },
      CANCELLED: { dot: 'bg-[var(--red)]', text: 'text-[var(--red)]' },
      RUNNING:   { dot: 'bg-[var(--cyan)]', text: 'text-[var(--cyan)]' }
    };

    function timeAgo(dateStr){
      if(!dateStr) return '—';
      const diffMs = Date.now() - new Date(dateStr).getTime();
      const mins = Math.floor(diffMs / 60000);
      if (mins < 1) return 'just now';
      if (mins < 60) return `${mins}m ago`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}h ago`;
      const days = Math.floor(hrs / 24);
      return `${days}d ago`;
    }

    function shortModel(model){
      if(!model) return '';
      const name = model.split('/')[1] || model;
      return name.length > 14 ? name.slice(0, 14) + '…' : name;
    }

    async function loadRecentWorkflows(){
      const container = document.getElementById('recent-workflows');
      try {
        const history = await MeshFlowAPI.getHistory();
        const runs = Array.isArray(history) ? history : (history?.data || []);

        if (!runs.length) {
          container.innerHTML = `
            <div class="col-span-full rounded-2xl border border-dashed border-white/10 py-10 text-center">
              <p class="text-[var(--text-muted)] text-sm mb-3">No workflows run yet.</p>
              <a href="#master-generate-form" class="text-xs font-medium text-[var(--cyan)] hover:underline">Generate your first one above ↑</a>
            </div>`;
          return;
        }

        container.innerHTML = runs.slice(0, 6).map(run => {
          const style = STATUS_STYLES[run.status] || STATUS_STYLES.RUNNING;
          const models = (run.modelsUsed || []).slice(0, 2);
          return `
            <div class="workflow-card rounded-2xl border border-white/10 bg-[var(--bg-elevated)] p-5">
              <div class="flex items-start justify-between mb-4">
                <span class="inline-flex items-center gap-1.5 text-[11px] font-mono uppercase ${style.text}">
                  <span class="status-dot ${style.dot}"></span>${run.status.toLowerCase()}
                </span>
                <div class="flex gap-1.5">
                  ${models.map(m => `<span class="provider-badge font-mono text-[10px] px-2 py-1 rounded-md border border-white/10 text-[var(--text-faint)]">${shortModel(m)}</span>`).join('')}
                </div>
              </div>
              <h4 class="font-display font-semibold text-[15px] mb-3 truncate">${run.workflowName || 'Untitled workflow'}</h4>
              <div class="flex items-center justify-between text-xs font-mono text-[var(--text-muted)] border-t border-white/[0.06] pt-3">
                <span>$${(run.totalCost || 0).toFixed(4)}</span>
                <span>${((run.totalLatency || 0) / 1000).toFixed(1)}s</span>
                <span class="text-[var(--text-faint)]">${timeAgo(run.startedAt)}</span>
              </div>
            </div>`;
        }).join('');
      } catch (err) {
        console.error('[Recent Workflows] failed to load:', err);
      }
    }

    document.addEventListener('DOMContentLoaded', loadRecentWorkflows);
</script>
</body>
</html>












<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MeshFlow X — Home</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script src="/js/api-services.js"></script>
<style>
  :root {
    --bg-base: #0B0E14;
    --bg-elevated: #12161F;
    --bg-elevated-2: #171C27;
    --border: rgba(255,255,255,0.08);
    --border-strong: rgba(255,255,255,0.16);
    --text-primary: #F3F5F7;
    --text-muted: #8A93A3;
    --text-faint: #5B6472;
    --cyan: #5EEAD4;
    --violet: #8B7CF6;
    --warm: #F5A97F;
    --red: #F87171;
  }

  * { box-sizing: border-box; }

  body {
    background: var(--bg-base);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .font-display { font-family: 'Space Grotesk', sans-serif; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }

  ::selection { background: rgba(94,234,212,0.25); color: #fff; }

  *:focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 2px;
    border-radius: 6px;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
  }

  /* ---------- Ambient background ---------- */
  .grid-texture {
    background-image:
      linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(ellipse 90% 60% at 50% 0%, black 30%, transparent 80%);
  }

  .ambient-glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(90px);
    opacity: 0.35;
    pointer-events: none;
  }

  @keyframes drift-1 {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(40px,-30px) scale(1.08); }
  }
  @keyframes drift-2 {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-50px,40px) scale(1.1); }
  }
  @keyframes drift-3 {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(30px,30px) scale(0.95); }
  }

  .glow-cyan { background: var(--cyan); animation: drift-1 18s ease-in-out infinite; }
  .glow-violet { background: var(--violet); animation: drift-2 22s ease-in-out infinite; }
  .glow-warm { background: var(--warm); animation: drift-3 26s ease-in-out infinite; opacity: 0.18; }

  /* floating mesh particles */
  .mesh-node {
    position: absolute;
    width: 4px; height: 4px;
    border-radius: 9999px;
    background: var(--cyan);
    box-shadow: 0 0 8px 2px rgba(94,234,212,0.5);
    animation: float-node 9s ease-in-out infinite;
    opacity: 0.5;
  }
  @keyframes float-node {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.25; }
    50% { transform: translateY(-22px) translateX(10px); opacity: 0.7; }
  }

  /* ---------- Hero title ---------- */
  .hero-gradient-text {
    background: linear-gradient(90deg, #F3F5F7 0%, #F3F5F7 40%, var(--cyan) 70%, var(--violet) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    background-size: 200% 100%;
    animation: hero-shift 8s ease infinite;
  }
  @keyframes hero-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .brand-mark {
    background: linear-gradient(135deg, var(--cyan), var(--violet));
  }

  /* ---------- Dropzone ---------- */
  .dropzone {
    position: relative;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.005));
    transition: transform .35s ease, box-shadow .35s ease, background .35s ease;
  }

  .dropzone-border {
    position: absolute; inset: 0;
    border-radius: 24px;
    padding: 1.5px;
    background: linear-gradient(120deg, rgba(94,234,212,0.6), rgba(139,124,246,0.15) 35%, rgba(94,234,212,0.6) 70%);
    background-size: 300% 300%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: border-flow 6s linear infinite;
    opacity: 0.55;
  }
  .dropzone:hover .dropzone-border { opacity: 0.9; }
  @keyframes border-flow {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  .dropzone:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px -20px rgba(94,234,212,0.15);
  }

  .dropzone.drag-over {
    transform: scale(1.015);
    background: linear-gradient(180deg, rgba(94,234,212,0.06), rgba(139,124,246,0.03));
    box-shadow: 0 0 0 1px rgba(94,234,212,0.4), 0 25px 70px -20px rgba(94,234,212,0.35);
  }
  .dropzone.drag-over .dropzone-border {
    opacity: 1;
    animation-duration: 2s;
  }

  @keyframes float-icon {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(-3deg); }
  }
  .upload-icon-wrap { animation: float-icon 3.4s ease-in-out infinite; }
  .dropzone.drag-over .upload-icon-wrap { animation-duration: 1s; }

  .file-chip {
    transition: transform .2s ease, border-color .2s ease, color .2s ease;
  }
  .file-chip:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong);
    color: var(--text-primary);
  }

  .btn-browse {
    transition: all .2s ease;
  }
  .btn-browse:hover {
    border-color: rgba(94,234,212,0.5);
    box-shadow: 0 0 0 1px rgba(94,234,212,0.2), 0 10px 25px -10px rgba(94,234,212,0.25);
    transform: translateY(-1px);
  }
  .btn-browse:active { transform: translateY(0); }

  /* ---------- Prompt composer ---------- */
  .composer {
    transition: box-shadow .3s ease, border-color .3s ease;
  }
  .composer.is-focused {
    border-color: rgba(139,124,246,0.5);
    box-shadow: 0 0 0 1px rgba(139,124,246,0.3), 0 20px 50px -20px rgba(139,124,246,0.3);
  }

  #prompt-textarea {
    resize: none;
    overflow: hidden;
  }

  .prompt-chip {
    transition: transform .18s ease, border-color .18s ease, background .18s ease;
  }
  .prompt-chip:hover {
    transform: translateY(-2px);
    border-color: rgba(139,124,246,0.4);
    background: rgba(139,124,246,0.08);
  }
  .prompt-chip:active { transform: translateY(0) scale(0.98); }

  /* ---------- Primary CTA ---------- */
  .cta-generate {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--cyan) 0%, var(--violet) 100%);
    transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
    box-shadow: 0 15px 40px -15px rgba(139,124,246,0.5);
  }
  .cta-generate:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 50px -12px rgba(139,124,246,0.65);
    filter: brightness(1.05);
  }
  .cta-generate:active {
    transform: translateY(0px) scale(0.985);
  }
  .cta-generate::before {
    content: '';
    position: absolute;
    top: 0; left: -60%;
    width: 40%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.55), transparent);
    transform: skewX(-20deg);
    animation: shine 3.2s ease-in-out infinite;
  }
  @keyframes shine {
    0% { left: -60%; }
    45%, 100% { left: 140%; }
  }
  .cta-generate:disabled {
    cursor: not-allowed;
    filter: saturate(0.7) brightness(0.9);
    transform: none;
    box-shadow: none;
  }

  .spinner {
    width: 16px; height: 16px;
    border-radius: 9999px;
    border: 2px solid rgba(11,14,20,0.25);
    border-top-color: #0B0E14;
    animation: spin .7s linear infinite;
    display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ---------- Mesh workflow preview ---------- */
  .mesh-node-box {
    transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease, opacity .3s ease;
    opacity: 0;
    transform: translateY(10px) scale(0.96);
  }
  .mesh-node-box.revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .mesh-node-box.active-pulse {
    border-color: var(--cyan);
    box-shadow: 0 0 0 1px rgba(94,234,212,0.4), 0 0 24px rgba(94,234,212,0.25);
  }

  .mesh-connector {
    position: relative;
    flex: 1;
    height: 2px;
    background: var(--border);
    overflow: hidden;
    border-radius: 2px;
  }
  .mesh-connector::after {
    content: '';
    position: absolute;
    top: 0; left: -30%;
    width: 30%; height: 100%;
    background: linear-gradient(90deg, transparent, var(--cyan), var(--violet), transparent);
    opacity: 0;
  }
  .mesh-connector.pulse::after {
    opacity: 1;
    animation: travel 1.1s ease-in-out;
  }
  @keyframes travel {
    0% { left: -30%; }
    100% { left: 100%; }
  }

  /* ---------- Recent workflow cards ---------- */
  .workflow-card {
    position: relative;
    transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
  }
  .workflow-card::before {
    content: '';
    position: absolute; inset: 0;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(94,234,212,0.5), rgba(139,124,246,0.5));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity .3s ease;
  }
  .workflow-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 45px -20px rgba(94,234,212,0.2);
  }
  .workflow-card:hover::before { opacity: 1; }

  .provider-badge {
    transition: transform .15s ease;
  }
  .workflow-card:hover .provider-badge { transform: translateY(-1px); }

  /* scrollbar */
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 9999px; }
</style>
</head>
