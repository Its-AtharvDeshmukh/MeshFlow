  <main class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 pt-14 pb-24">

    <section class="text-center max-w-3xl mx-auto mb-14">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/[0.03] text-xs font-mono text-[var(--text-muted)] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--cyan)]"></span>
        Mesh API — live session
      </span>
      <h1 class="font-display text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05] hero-gradient-text mb-5">
        Turn raw files into<br class="hidden md:block" /> working AI pipelines
      </h1>
