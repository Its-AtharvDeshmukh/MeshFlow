  </main>

<script>
    lucide.createIcons();

    // ---------- Ambient particles ----------
    (function(){
      const container = document.getElementById('mesh-particles');
      const count = window.innerWidth < 768 ? 10 : 20;
      for(let i=0;i<count;i++){
        const p = document.createElement('div');
        p.className = 'mesh-node';
        p.style.top = Math.random()*100 + '%';
        p.style.left = Math.random()*100 + '%';
        p.style.animationDelay = (Math.random()*6) + 's';
        p.style.animationDuration = (7 + Math.random()*6) + 's';
        if(i % 3 === 0){ p.style.background = 'var(--violet)'; p.style.boxShadow = '0 0 8px 2px rgba(139,124,246,0.5)'; }
        container.appendChild(p);
      }
    })();

    // ---------- Dropzone & Document Verification Gate ----------
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('file-input');
    const browseBtn = document.getElementById('browse-btn');
    const fileStatus = document.getElementById('file-status');
    const generateBtn = document.getElementById('generate-btn');
    const masterForm = document.getElementById('master-generate-form');
    
    // HARD DISABLE INITIALLY - Await verification gate
    generateBtn.disabled = true; 

    browseBtn.addEventListener('click', (e) => { e.stopPropagation(); fileInput.click(); });
    dropzone.addEventListener('click', () => fileInput.click());

    ['dragenter','dragover'].forEach(evt => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault(); e.stopPropagation();
        dropzone.classList.add('drag-over');
      });
    });
    ['dragleave','drop'].forEach(evt => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault(); e.stopPropagation();
        if(evt === 'dragleave' && e.target !== dropzone) return;
        dropzone.classList.remove('drag-over');
      });
    });

    dropzone.addEventListener('drop', (e) => {
      const files = e.dataTransfer.files;
      if(files && files.length > 0) {
        const dt = new DataTransfer();
        dt.items.add(files[0]);
        fileInput.files = dt.files;
        fileInput.dispatchEvent(new Event('change')); // Trigger Verification
      }
    });

    fileInput.addEventListener('change', async () => {
        if(!fileInput.files.length) return;
        const file = fileInput.files[0];
        
        fileStatus.innerHTML = '<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin inline-block align-middle"></i> Verifying Document...';
        fileStatus.classList.remove('hidden');
        fileStatus.classList.replace('text-[var(--red)]', 'text-[var(--cyan)]');
        lucide.createIcons();

        const fd = new FormData();
        fd.append('file', file);

        try {
            const response = await fetch('/api/validate-document', { method: 'POST', body: fd });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Validation failed');
            }

            if (data.warning === "DOCUMENT_TOO_SHORT") {
                const proceed = confirm(`The uploaded document appears incomplete (${data.textLength} characters). Do you want to continue?`);
                if (!proceed) {
                    fileInput.value = '';
                    fileStatus.classList.add('hidden');
                    return;
                }
            }

            // Display Document Ready Panel
            document.getElementById('dropzone').classList.add('hidden');
            const readyPanel = document.getElementById('document-ready-panel');
            readyPanel.classList.remove('hidden');
            readyPanel.classList.add('flex', 'animate-in', 'fade-in', 'zoom-in-95', 'duration-500');
            
            // Populate Metadata
            document.getElementById('verified-document-id').value = data.documentId;
            document.getElementById('doc-meta-name').textContent = data.metadata.name;
            document.getElementById('doc-meta-pages').textContent = data.metadata.pages;
            document.getElementById('doc-meta-words').textContent = data.metadata.words;
            document.getElementById('doc-meta-chars').textContent = data.metadata.chars;
            document.getElementById('doc-meta-lang').textContent = data.metadata.language;
            document.getElementById('doc-meta-type').textContent = data.metadata.fileType;
            document.getElementById('doc-meta-ocr').textContent = data.metadata.ocr;
            
            // UNLOCK WORKFLOW GENERATION
            generateBtn.disabled = false;
            generateBtn.classList.add('shadow-[0_0_30px_rgba(94,234,212,0.4)]');

        } catch (err) {
            fileStatus.innerHTML = `<i data-lucide="alert-triangle" class="w-3.5 h-3.5 inline-block align-middle"></i> ${err.message}`;
            fileStatus.classList.replace('text-[var(--cyan)]', 'text-[var(--red)]');
            generateBtn.disabled = true;
            lucide.createIcons();
        }
    });

    // ---------- Auto-growing textarea ----------
    const textarea = document.getElementById('prompt-textarea');
    const composer = textarea.closest('.composer');
    function autoGrow(){
      textarea.style.height = 'auto';
      textarea.style.height = Math.min(textarea.scrollHeight, 260) + 'px';
    }
    textarea.addEventListener('input', autoGrow);
    textarea.addEventListener('focus', () => composer.classList.add('is-focused'));
    textarea.addEventListener('blur', () => composer.classList.remove('is-focused'));
    autoGrow();

    // ---------- Prompt chips ----------
    document.querySelectorAll('.prompt-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const examples = {
          'Summarize Document': 'Summarize this document into 5 key bullet points.',
          'Analyze Invoice': 'Extract line items, totals, and flag discrepancies in this invoice.',
          'Generate Report': 'Turn this data into a structured executive report.',
          'Research Topic': 'Research this topic and compile the top findings with sources.'
        };
        textarea.value = examples[chip.dataset.prompt] || chip.dataset.prompt;
        textarea.focus();
        autoGrow();
      });
    });

    // ---------- Generate CTA + Mesh preview ----------
    const ctaLabel = document.getElementById('cta-label');
    const previewEmpty = document.getElementById('preview-empty');
    const previewMesh = document.getElementById('preview-mesh');
    const previewStatus = document.getElementById('preview-status');
    const stages = ['Upload','OCR','Summarize','Reason','Export'];
    
    function buildMesh(stageArray = stages){
      previewMesh.innerHTML = '';
      previewMesh.classList.remove('hidden');
      previewMesh.classList.add('flex');
      
      stageArray.forEach((stage, i) => {
        const node = document.createElement('div');
        node.className = 'mesh-node-box flex-1 min-w-[110px] rounded-xl border border-white/10 bg-[var(--bg-elevated-2)] py-4 text-center';
        node.innerHTML = '<p class="text-[10px] font-mono text-[var(--text-faint)] mb-1">0' + (i+1) + '</p>' +
                          '<p class="font-display font-semibold text-sm truncate px-2">' + stage + '</p>';
        previewMesh.appendChild(node);
        
        if(i < stageArray.length - 1){
          const connector = document.createElement('div');
          connector.className = 'mesh-connector';
          previewMesh.appendChild(connector);
        }
      });
    }

    function animateMesh(){
      const nodes = previewMesh.querySelectorAll('.mesh-node-box');
      const connectors = previewMesh.querySelectorAll('.mesh-connector');
      nodes.forEach((node, i) => {
        setTimeout(() => {
          node.classList.add('revealed');
          node.classList.add('active-pulse');
          setTimeout(() => node.classList.remove('active-pulse'), 700);
          if(connectors[i]){
            setTimeout(() => connectors[i].classList.add('pulse'), 350);
          }
        }, i * 450);
      });
    }

    // ---------- Master API Integration ----------
    masterForm.addEventListener('submit', async (event) => {
      event.preventDefault(); 
      if (generateBtn.disabled) return;
      
      const promptText = textarea.value.trim();
      const docId = document.getElementById('verified-document-id').value;
      
      if(!docId) return alert("Please upload and validate a document before generating a workflow.");
      if(!promptText) { alert("Please describe the workflow."); return; }

      generateBtn.disabled = true;
      
      // Start UI Animations
      const originalLabel = ctaLabel.innerHTML;
      ctaLabel.innerHTML = '<span class="spinner"></span> Processing & Generating…';
      previewStatus.textContent = 'running';
      previewEmpty.classList.add('hidden');
      
      buildMesh();
      animateMesh();

      try {
        const payload = new FormData();
        payload.append('prompt', promptText);
        payload.append('documentId', docId);

        const response = await fetch('/api/generate-workflow', { 
            method: 'POST', 
            body: payload 
        });
        const workflowData = await response.json();
        
        if (!response.ok) throw new Error(workflowData.error || 'API request failed');
        
        // Store in localStorage
        localStorage.setItem('meshWorkflow', JSON.stringify(workflowData.workflow || workflowData));
        
        if (workflowData.workflow?.steps && Array.isArray(workflowData.workflow.steps)) {
            buildMesh(workflowData.workflow.steps.map(s => s.taskName || s.name || 'Compute Node'));
            animateMesh();
        }

        // Show Success
        ctaLabel.textContent = '✓ Workflow Ready';
        previewStatus.textContent = 'complete';
        
        // Redirect to Builder after a short delay
        setTimeout(() => {
          window.location.href = '/builder';
        }, 800);
        
      } catch (error) {
        console.error("Workflow Generation Error:", error);
        alert("Generation Failed: " + error.message);
        
        ctaLabel.textContent = '❌ Generation Failed';
        previewStatus.textContent = 'failed';
        
        // Reset button after error
        setTimeout(() => {
          ctaLabel.innerHTML = originalLabel;
          generateBtn.disabled = false;
        }, 2500);
      }
    });

    // ---------- Recent workflows (live data) ----------
    const STATUS_STYLES = {
      COMPLETED: { dot: 'bg-emerald-400', text: 'text-emerald-400' },
      FAILED:    { dot: 'bg-[var(--red)]', text: 'text-[var(--red)]' },
      CANCELLED: { dot: 'bg-[var(--red)]', text: 'text-[var(--red)]' },
      RUNNING:   { dot: 'bg-[var(--cyan)]', text: 'text-[var(--cyan)]' }
    };

    function timeAgo(dateStr){
      if(!dateStr) return '—';
      const diffMs = Date.now() - new Date(dateStr).getTime();
      const mins = Math.floor(diffMs / 60000);
      if (mins < 1) return 'just now';
      if (mins < 60) return `${mins}m ago`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}h ago`;
      const days = Math.floor(hrs / 24);
      return `${days}d ago`;
    }

    function shortModel(model){
      if(!model) return '';
      const name = model.split('/')[1] || model;
      return name.length > 14 ? name.slice(0, 14) + '…' : name;
    }

    async function loadRecentWorkflows(){
      const container = document.getElementById('recent-workflows');
      try {
        const history = await MeshFlowAPI.getHistory();
        const runs = Array.isArray(history) ? history : (history?.data || []);

        if (!runs.length) {
          container.innerHTML = `
            <div class="col-span-full rounded-2xl border border-dashed border-white/10 py-10 text-center">
              <p class="text-[var(--text-muted)] text-sm mb-3">No workflows run yet.</p>
              <a href="#master-generate-form" class="text-xs font-medium text-[var(--cyan)] hover:underline">Generate your first one above ↑</a>
            </div>`;
          return;
        }

        container.innerHTML = runs.slice(0, 6).map(run => {
          const style = STATUS_STYLES[run.status] || STATUS_STYLES.RUNNING;
          const models = (run.modelsUsed || []).slice(0, 2);
          return `
            <div class="workflow-card rounded-2xl border border-white/10 bg-[var(--bg-elevated)] p-5">
              <div class="flex items-start justify-between mb-4">
                <span class="inline-flex items-center gap-1.5 text-[11px] font-mono uppercase ${style.text}">
                  <span class="status-dot ${style.dot}"></span>${run.status.toLowerCase()}
                </span>
                <div class="flex gap-1.5">
                  ${models.map(m => `<span class="provider-badge font-mono text-[10px] px-2 py-1 rounded-md border border-white/10 text-[var(--text-faint)]">${shortModel(m)}</span>`).join('')}
                </div>
              </div>
              <h4 class="font-display font-semibold text-[15px] mb-3 truncate">${run.workflowName || 'Untitled workflow'}</h4>
              <div class="flex items-center justify-between text-xs font-mono text-[var(--text-muted)] border-t border-white/[0.06] pt-3">
                <span>$${(run.totalCost || 0).toFixed(4)}</span>
                <span>${((run.totalLatency || 0) / 1000).toFixed(1)}s</span>
                <span class="text-[var(--text-faint)]">${timeAgo(run.startedAt)}</span>
              </div>
            </div>`;
        }).join('');
      } catch (err) {
        console.error('[Recent Workflows] failed to load:', err);
      }
    }

    document.addEventListener('DOMContentLoaded', loadRecentWorkflows);
</script>
</body>
</html>