      <div class="flex items-center gap-2.5">
        <span class="w-7 h-7 rounded-lg brand-mark flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <circle cx="5" cy="6" r="2" fill="#0B0E14"/>
            <circle cx="19" cy="6" r="2" fill="#0B0E14"/>
            <circle cx="12" cy="18" r="2" fill="#0B0E14"/>
